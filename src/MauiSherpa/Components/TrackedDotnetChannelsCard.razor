        width: 100%;
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 0.9rem;
        padding: 0 10.75rem 0 0;
        border: 0;
        background: transparent;
        color: inherit;
        font: inherit;
        text-align: left;
        cursor: pointer;
    }

    .tdc-toggle:hover {
        color: inherit;
    }

    .tdc-toggle:focus-visible,
