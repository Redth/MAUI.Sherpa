    }

    .device-card-icon.platform-android {
        background: rgba(34, 197, 94, 0.12);
        color: #22c55e;
    }

    .device-card-icon.platform-apple {
        background: rgba(147, 51, 234, 0.12);
        color: #9333ea;
    }

    .device-card-icon.platform-windows {
        background: rgba(59, 130, 246, 0.12);
        color: #3b82f6;
    }

    :global(.theme-dark) .device-card-icon.platform-android {
        color: #4ade80;
    }

    :global(.theme-dark) .device-card-icon.platform-apple {
        color: #c084fc;
    }

    :global(.theme-dark) .device-card-icon.platform-windows {
        color: #60a5fa;
    }

    .device-card-info {
        flex: 1;
        min-width: 0;
    }

    .device-card-name {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .device-card-detail {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .device-card-action {
        width: 30px;
        height: 30px;
        border-radius: 0.5rem;
        border: none;
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        flex-shrink: 0;
        transition: all 0.15s;
    }

    .device-card-action:hover {
        background: var(--accent-primary);
