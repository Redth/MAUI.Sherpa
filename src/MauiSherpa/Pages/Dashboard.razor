        font-size: 0.8rem;
        font-weight: 600;
    }

    .release-notes-trigger:hover { color: var(--text-primary); background: var(--bg-hover); }

    .environment-section { margin-bottom: 2rem; }

    .section-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
