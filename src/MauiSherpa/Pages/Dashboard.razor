        align-items: center;
        gap: 0.5rem;
    }

    .devices-section h2 i {
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .devices-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 0.625rem;
    }

    .device-card {
        display: flex;
        align-items: center;
