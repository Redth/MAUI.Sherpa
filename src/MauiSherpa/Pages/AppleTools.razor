@page "/apple-tools"
@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Core.ViewModels
@inject AppleToolsViewModel ViewModel
@inject IPlatformService Platform
@inject IAlertService AlertService
@inject IOperationModalService OperationModal

<h1><i class="fab fa-apple"></i> @ViewModel.Title</h1>

@if (!Platform.IsMacCatalyst && !Platform.IsMacOS)
{
    <div class="not-supported">
        <div class="warning-icon"><i class="fas fa-exclamation-triangle"></i></div>
        <h2>macOS Only</h2>
        <p>Apple development tools management requires macOS with Xcode installed.</p>
    </div>
}
else
{
    <div class="status-bar">
        <span class="status-label">Status:</span>
        <span class="status-text">@ViewModel.StatusMessage</span>
        @if (ViewModel.IsSignedIn)
        {
            <span class="auth-status signed-in">
                <i class="fas fa-check-circle"></i> @ViewModel.SignedInAppleId
                <button class="btn-link" @onclick="SignOut">Sign Out</button>
            </span>
        }
    </div>

    <div class="toolbar">
        <button class="btn btn-primary" @onclick="RefreshInstalled" disabled="@ViewModel.IsLoading">
            <i class="fas fa-sync-alt"></i> @(ViewModel.IsLoading ? "Loading..." : "Refresh")
        </button>
    </div>

    <div class="tabs">
        <button class="tab @(activeTab == "installed" ? "active" : "")" @onclick="@(() => SwitchTab("installed"))">
            <i class="fas fa-hdd"></i> Installed (@ViewModel.InstalledXcodes.Count)
        </button>
        <button class="tab @(activeTab == "available" ? "active" : "")" @onclick="@(() => SwitchTab("available"))">
            <i class="fas fa-cloud-download-alt"></i> Available
            @if (ViewModel.AvailableReleases.Count > 0)
            {
                <span class="tab-count">(@ViewModel.FilteredAvailableReleases.Count)</span>
            }
        </button>
    </div>

    @if (activeTab == "installed")
    {
        @if (ViewModel.IsLoading && ViewModel.InstalledXcodes.Count == 0)
        {
            <div class="loading-state">
                <div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>
                <div class="loading-title">Discovering Xcode Installations</div>
                <div class="loading-description">Scanning /Applications for Xcode bundles...</div>
            </div>
        }
        else if (ViewModel.InstalledXcodes.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-box-open"></i></div>
                <h3>No Xcode Installations Found</h3>
                <p>Install Xcode from the Mac App Store or download from the Available tab.</p>
            </div>
        }
        else
        {
            <div class="xcode-list">
                @foreach (var xcode in ViewModel.InstalledXcodes)
                {
                    <div class="xcode-card @(xcode.IsSelected ? "selected" : "")">
                        <div class="xcode-card-icon">
                            <i class="fas fa-hammer"></i>
                        </div>
                        <div class="xcode-card-info">
                            <div class="xcode-card-title">
                                Xcode @xcode.Version
                                @if (xcode.IsSelected)
                                {
                                    <span class="badge badge-active"><i class="fas fa-check"></i> Active</span>
                                }
                            </div>
                            <div class="xcode-card-details">
                                <span class="detail-item"><i class="fas fa-code-branch"></i> Build @xcode.BuildNumber</span>
                                <span class="detail-item"><i class="fas fa-folder"></i> @xcode.Path</span>
                            </div>
                        </div>
                        <div class="xcode-card-actions">
                            @if (!xcode.IsSelected)
                            {
                                <button class="btn btn-sm btn-outline" @onclick="() => SelectXcode(xcode)">
                                    <i class="fas fa-check-circle"></i> Select
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }

    @if (activeTab == "available")
    {
        <div class="available-controls">
            <label class="toggle-label">
                <input type="checkbox" @bind="showBetas" @bind:event="oninput" />
                <span>Show Betas &amp; RCs</span>
            </label>
            @if (ViewModel.IsLoadingAvailable)
            {
                <span class="loading-indicator"><i class="fas fa-spinner fa-spin"></i> Fetching releases...</span>
            }
        </div>

        @if (ViewModel.IsLoadingAvailable && filteredReleases.Count == 0)
        {
            <div class="loading-state">
                <div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>
                <div class="loading-title">Fetching Available Releases</div>
                <div class="loading-description">Querying xcodereleases.com...</div>
            </div>
        }
        else if (filteredReleases.Count > 0)
        {
            <div class="results-info">Showing @filteredReleases.Count releases</div>
            <div class="xcode-list">
                @foreach (var release in filteredReleases)
                {
                    var installed = ViewModel.IsInstalled(release);
                    <div class="xcode-card @(installed ? "installed" : "")">
                        <div class="xcode-card-icon">
                            @if (release.IsBeta)
                            {
                                <i class="fas fa-flask"></i>
                            }
                            else
                            {
                                <i class="fas fa-hammer"></i>
                            }
                        </div>
                        <div class="xcode-card-info">
                            <div class="xcode-card-title">
                                Xcode @release.Version
                                @if (release.IsBeta)
                                {
                                    <span class="badge badge-beta">Beta</span>
                                }
                                @if (installed)
                                {
                                    <span class="badge badge-installed"><i class="fas fa-check"></i> Installed</span>
                                }
                            </div>
                            <div class="xcode-card-details">
                                <span class="detail-item"><i class="fas fa-code-branch"></i> Build @release.BuildNumber</span>
                                <span class="detail-item"><i class="fas fa-calendar"></i> @release.ReleaseDate.ToString("MMM d, yyyy")</span>
                                @if (!string.IsNullOrEmpty(release.MinimumMacOSVersion))
                                {
                                    <span class="detail-item"><i class="fas fa-desktop"></i> macOS @release.MinimumMacOSVersion+</span>
                                }
                            </div>
                            @if (release.Sdks.Count > 0)
                            {
                                <div class="xcode-card-sdks">
                                    @foreach (var sdk in release.Sdks.Take(5))
                                    {
                                        <span class="sdk-tag">@sdk.Name @sdk.Version</span>
                                    }
                                    @if (release.Sdks.Count > 5)
                                    {
                                        <span class="sdk-tag more">+@(release.Sdks.Count - 5) more</span>
                                    }
                                </div>
                            }
                            @if (release.Compilers.Count > 0)
                            {
                                <div class="xcode-card-compilers">
                                    @foreach (var compiler in release.Compilers)
                                    {
                                        <span class="compiler-tag">@compiler.Name @compiler.Version</span>
                                    }
                                </div>
                            }
                        </div>
                        <div class="xcode-card-actions">
                            @if (!string.IsNullOrEmpty(release.ReleaseNotesUrl))
                            {
                                <button class="btn btn-sm btn-ghost" @onclick="() => OpenUrl(release.ReleaseNotesUrl)">
                                    <i class="fas fa-file-alt"></i>
                                </button>
                            }
                            @if (!installed && !string.IsNullOrEmpty(release.DownloadUrl))
                            {
                                <button class="btn btn-sm btn-outline" @onclick="() => DownloadXcode(release)">
                                    <i class="fas fa-download"></i> Download
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }

    @* ── Apple ID Sign-In Modal ── *@
    @if (showSignInModal)
    {
        <div class="modal-overlay" @onclick="CloseSignInModal">
            <div class="modal" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3><i class="fab fa-apple"></i> Apple Developer Sign In</h3>
                    <button class="modal-close" @onclick="CloseSignInModal"><i class="fas fa-times"></i></button>
                </div>
                <div class="modal-body">
                    @if (!showTwoFactorInput)
                    {
                        <p class="modal-description">Sign in with your Apple ID to download Xcode from Apple Developer.</p>
                        @if (!string.IsNullOrEmpty(signInError))
                        {
                            <div class="modal-error"><i class="fas fa-exclamation-circle"></i> @signInError</div>
                        }
                        <div class="form-group">
                            <label>Apple ID</label>
                            <input type="email" @bind="appleIdInput" @bind:event="oninput"
                                   placeholder="you@example.com" disabled="@isSigningIn" />
                        </div>
                        <div class="form-group">
                            <label>Password</label>
                            <input type="password" @bind="passwordInput" @bind:event="oninput"
                                   placeholder="Password" disabled="@isSigningIn" />
                        </div>
                    }
                    else
                    {
                        <p class="modal-description">Enter the 6-digit verification code sent to your trusted device.</p>
                        @if (!string.IsNullOrEmpty(signInError))
                        {
                            <div class="modal-error"><i class="fas fa-exclamation-circle"></i> @signInError</div>
                        }
                        <div class="form-group two-factor-group">
                            <label>Verification Code</label>
                            <input type="text" @bind="twoFactorInput" @bind:event="oninput"
                                   placeholder="000000" maxlength="6" class="two-factor-input"
                                   disabled="@isSigningIn" />
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseSignInModal" disabled="@isSigningIn">Cancel</button>
                    @if (!showTwoFactorInput)
                    {
                        <button class="btn btn-primary" @onclick="SubmitSignIn"
                                disabled="@(isSigningIn || string.IsNullOrWhiteSpace(appleIdInput) || string.IsNullOrWhiteSpace(passwordInput))">
                            @if (isSigningIn) { <i class="fas fa-spinner fa-spin"></i> } Sign In
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary" @onclick="SubmitTwoFactor"
                                disabled="@(isSigningIn || string.IsNullOrWhiteSpace(twoFactorInput) || twoFactorInput?.Length < 6)">
                            @if (isSigningIn) { <i class="fas fa-spinner fa-spin"></i> } Verify
                        </button>
                    }
                </div>
            </div>
        </div>
    }
}

<style>
    h1 {
        margin-bottom: 1.25rem;
        font-size: 1.75rem;
        color: var(--text-primary);
    }

    .not-supported {
        text-align: center;
        padding: 3.75rem 1.25rem;
        background: var(--status-error-bg);
        border-radius: 0.75rem;
        border: 1px solid var(--accent-danger);
    }
    .not-supported .warning-icon { font-size: 48px; margin-bottom: 1rem; color: var(--accent-warning); }
    .not-supported .warning-icon i { font-size: 48px; }
    .not-supported h2 { color: var(--accent-danger); margin-bottom: 0.5rem; }
    .not-supported p { color: var(--text-muted); }

    .status-bar {
        background: var(--card-bg);
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1rem;
        border: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .status-label { font-weight: 600; color: var(--text-primary); }
    .status-text { color: var(--text-secondary); flex: 1; }

    .auth-status {
        font-size: 0.8125rem;
        display: flex;
        align-items: center;
        gap: 0.375rem;
        margin-left: auto;
    }
    .auth-status.signed-in { color: var(--accent-success); }
    .auth-status .btn-link {
        background: none;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 0.75rem;
        text-decoration: underline;
        padding: 0;
    }
    .auth-status .btn-link:hover { color: var(--accent-danger); }

    .toolbar {
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Tabs */
    .tabs {
        display: flex;
        gap: 0.25rem;
        margin-bottom: 1rem;
        border-bottom: 2px solid var(--border-color);
    }
    .tab {
        padding: 0.75rem 1.25rem;
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--text-muted);
        font-size: 0.875rem;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .tab:hover { color: var(--accent-primary); }
    .tab.active {
        color: var(--accent-primary);
        border-bottom-color: var(--accent-primary);
        font-weight: 600;
    }
    .tab-count { opacity: 0.7; }

    /* Loading & Empty States */
    .loading-state, .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        background: var(--card-bg);
        border-radius: var(--card-radius);
        border: 1px solid var(--border-color);
    }
    .loading-spinner { font-size: 2rem; color: var(--accent-primary); margin-bottom: 1rem; }
    .loading-title, .empty-state h3 { font-size: 1.125rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; }
    .loading-description, .empty-state p { color: var(--text-muted); font-size: 0.875rem; }
    .empty-icon { font-size: 2.5rem; color: var(--text-muted); margin-bottom: 1rem; opacity: 0.5; }

    /* Xcode Cards */
    .xcode-list { display: flex; flex-direction: column; gap: 0.5rem; }

    .xcode-card {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--card-radius);
        transition: all 0.15s ease;
    }
    .xcode-card:hover { border-color: var(--accent-primary); box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .xcode-card.selected { border-color: var(--accent-success); background: var(--status-success-bg); }
    .xcode-card.installed { border-left: 3px solid var(--accent-success); }

    .xcode-card-icon {
        font-size: 1.5rem;
        color: var(--accent-primary);
        padding-top: 0.125rem;
        flex-shrink: 0;
        width: 2rem;
        text-align: center;
    }
    .xcode-card.selected .xcode-card-icon { color: var(--accent-success); }

    .xcode-card-info { flex: 1; min-width: 0; }

    .xcode-card-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .xcode-card-details {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 0.375rem;
        font-size: 0.8125rem;
        color: var(--text-muted);
    }
    .detail-item { display: flex; align-items: center; gap: 0.375rem; }
    .detail-item i { font-size: 0.6875rem; opacity: 0.7; }

    .xcode-card-sdks, .xcode-card-compilers {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        margin-top: 0.5rem;
    }

    .sdk-tag {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        font-size: 0.6875rem;
        border-radius: 0.25rem;
        background: var(--bg-tertiary);
        color: var(--text-secondary);
        border: 1px solid var(--border-color);
    }
    .sdk-tag.more { font-style: italic; opacity: 0.7; }

    .compiler-tag {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        font-size: 0.6875rem;
        border-radius: 0.25rem;
        background: rgba(66, 153, 225, 0.1);
        color: var(--accent-primary);
        border: 1px solid rgba(66, 153, 225, 0.2);
    }

    .xcode-card-actions {
        display: flex;
        gap: 0.375rem;
        flex-shrink: 0;
        align-items: flex-start;
    }

    /* Badges */
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.125rem 0.5rem;
        font-size: 0.6875rem;
        font-weight: 600;
        border-radius: 1rem;
    }
    .badge-active {
        background: var(--accent-success);
        color: white;
    }
    .badge-beta {
        background: rgba(237, 137, 54, 0.15);
        color: var(--accent-warning);
        border: 1px solid rgba(237, 137, 54, 0.3);
    }
    .badge-installed {
        background: rgba(72, 187, 120, 0.15);
        color: var(--accent-success);
        border: 1px solid rgba(72, 187, 120, 0.3);
    }

    /* Buttons */
    .btn-sm {
        padding: 0.375rem 0.75rem;
        font-size: 0.8125rem;
    }
    .btn-outline {
        background: transparent;
        border: 1px solid var(--accent-primary);
        color: var(--accent-primary);
        border-radius: 0.375rem;
        cursor: pointer;
        transition: all 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
    }
    .btn-outline:hover { background: var(--accent-primary); color: white; }

    .btn-ghost {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        border-radius: 0.375rem;
        cursor: pointer;
        transition: all 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
    }
    .btn-ghost:hover { color: var(--accent-primary); border-color: var(--accent-primary); }

    .btn-secondary {
        background: var(--bg-tertiary);
        border: 1px solid var(--border-color);
        color: var(--text-secondary);
        padding: 0.5rem 1rem;
        border-radius: 0.375rem;
        cursor: pointer;
        font-size: 0.875rem;
    }
    .btn-secondary:hover { background: var(--border-color); }

    /* Available Controls */
    .available-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
        padding: 0.75rem 1rem;
        background: var(--card-bg);
        border-radius: 0.5rem;
        border: 1px solid var(--border-color);
    }

    .toggle-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: var(--text-secondary);
        cursor: pointer;
    }
    .toggle-label input[type="checkbox"] { accent-color: var(--accent-primary); }

    .loading-indicator {
        font-size: 0.8125rem;
        color: var(--text-muted);
    }

    .results-info {
        font-size: 0.8125rem;
        color: var(--text-muted);
        margin-bottom: 0.75rem;
    }

    /* ── Sign-In Modal ── */
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }
    .modal {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 0.75rem;
        width: 420px;
        max-width: 90vw;
        box-shadow: 0 16px 48px rgba(0, 0, 0, 0.25);
    }
    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
    }
    .modal-header h3 {
        margin: 0;
        font-size: 1.125rem;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .modal-close {
        background: none;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 1rem;
        padding: 0.25rem;
    }
    .modal-close:hover { color: var(--text-primary); }
    .modal-body { padding: 1.5rem; }
    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border-color);
    }
    .modal-description {
        color: var(--text-secondary);
        font-size: 0.875rem;
        margin-bottom: 1.25rem;
    }
    .modal-error {
        background: var(--status-error-bg);
        color: var(--accent-danger);
        padding: 0.625rem 0.875rem;
        border-radius: 0.375rem;
        font-size: 0.8125rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .form-group {
        margin-bottom: 1rem;
    }
    .form-group label {
        display: block;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.375rem;
    }
    .form-group input {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--border-color);
        border-radius: 0.375rem;
        background: var(--bg-secondary);
        color: var(--text-primary);
        font-size: 0.875rem;
        box-sizing: border-box;
    }
    .form-group input:focus {
        outline: none;
        border-color: var(--accent-primary);
        box-shadow: 0 0 0 2px rgba(66, 153, 225, 0.2);
    }
    .form-group input:disabled { opacity: 0.6; }
    .two-factor-group { text-align: center; }
    .two-factor-input {
        font-size: 1.5rem !important;
        letter-spacing: 0.5rem;
        text-align: center;
        font-family: monospace;
        max-width: 220px;
        margin: 0 auto;
    }
</style>

@code {
    private string activeTab = "installed";
    private bool showBetas;
    private bool hasInitialized;

    // Sign-in modal state
    private bool showSignInModal;
    private bool showTwoFactorInput;
    private bool isSigningIn;
    private string? appleIdInput;
    private string? passwordInput;
    private string? twoFactorInput;
    private string? signInError;
    private XcodeRelease? pendingDownloadRelease;

    private IReadOnlyList<XcodeRelease> filteredReleases =>
        showBetas
            ? ViewModel.AvailableReleases.Take(50).ToList()
            : ViewModel.AvailableReleases.Where(r => !r.IsBeta).Take(50).ToList();

    protected override async Task OnInitializedAsync()
    {
        if (!hasInitialized)
        {
            hasInitialized = true;
            await ViewModel.LoadInstalledAsync();
        }
    }

    private async Task RefreshInstalled()
    {
        await ViewModel.LoadInstalledAsync();
    }

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        if (tab == "available" && ViewModel.AvailableReleases.Count == 0)
        {
            await ViewModel.LoadAvailableAsync();
        }
    }

    private async Task SelectXcode(XcodeInstallation xcode)
    {
        await ViewModel.SelectXcodeAsync(xcode);
        StateHasChanged();
    }

    private async Task DownloadXcode(XcodeRelease release)
    {
        if (!ViewModel.IsSignedIn)
        {
            // Need to sign in first — show modal and remember what to download
            pendingDownloadRelease = release;
            showSignInModal = true;
            showTwoFactorInput = false;
            signInError = null;
            appleIdInput = null;
            passwordInput = null;
            twoFactorInput = null;
            StateHasChanged();
            return;
        }

        await StartDownloadAsync(release);
    }

    private async Task StartDownloadAsync(XcodeRelease release)
    {
        var result = await OperationModal.RunAsync(
            $"Download Xcode {release.Version}",
            $"Downloading Xcode {release.Version} ({release.BuildNumber}) to ~/Downloads...",
            async ctx =>
            {
                ctx.SetStatus("Starting download...");
                ctx.LogInfo($"Downloading Xcode {release.Version} ({release.BuildNumber})");
                ctx.LogInfo($"URL: {release.DownloadUrl}");

                var progress = new Progress<XcodeDownloadProgress>(p =>
                {
                    if (ctx.IsCancellationRequested) return;
                    ctx.SetStatus(p.Status ?? "Downloading...");
                    if (p.PercentComplete > 0)
                        ctx.SetProgress((int)p.PercentComplete);
                });

                var success = await ViewModel.DownloadXcodeAsync(release, progress, ctx.CancellationToken);

                if (success)
                    ctx.LogSuccess("Download complete! File saved to ~/Downloads");
                else
                    ctx.LogError("Download failed — check that your Apple Developer session is still valid");

                return success;
            });

        if (result.Success)
        {
            await AlertService.ShowToastAsync($"Xcode {release.Version} downloaded to ~/Downloads");
        }
    }

    // ── Sign-In Modal Handlers ──

    private void CloseSignInModal()
    {
        showSignInModal = false;
        pendingDownloadRelease = null;
        passwordInput = null;
        twoFactorInput = null;
    }

    private async Task SubmitSignIn()
    {
        if (string.IsNullOrWhiteSpace(appleIdInput) || string.IsNullOrWhiteSpace(passwordInput)) return;

        isSigningIn = true;
        signInError = null;
        StateHasChanged();

        try
        {
            var result = await ViewModel.SignInAsync(appleIdInput.Trim(), passwordInput);

            switch (result)
            {
                case AppleSignInResult.Success:
                    showSignInModal = false;
                    passwordInput = null;
                    await AlertService.ShowToastAsync($"Signed in as {appleIdInput}");
                    // If there's a pending download, start it
                    if (pendingDownloadRelease != null)
                    {
                        var release = pendingDownloadRelease;
                        pendingDownloadRelease = null;
                        StateHasChanged();
                        await StartDownloadAsync(release);
                    }
                    break;

                case AppleSignInResult.TwoFactorRequired:
                    showTwoFactorInput = true;
                    twoFactorInput = null;
                    break;

                case AppleSignInResult.InvalidCredentials:
                    signInError = "Invalid Apple ID or password. Please try again.";
                    passwordInput = null;
                    break;

                case AppleSignInResult.AccountLocked:
                    signInError = "This Apple ID has been locked for security reasons.";
                    break;

                default:
                    signInError = "Sign-in failed. Please check your connection and try again.";
                    break;
            }
        }
        catch (Exception ex)
        {
            signInError = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isSigningIn = false;
            StateHasChanged();
        }
    }

    private async Task SubmitTwoFactor()
    {
        if (string.IsNullOrWhiteSpace(twoFactorInput) || twoFactorInput.Length < 6) return;

        isSigningIn = true;
        signInError = null;
        StateHasChanged();

        try
        {
            var success = await ViewModel.Verify2FAAsync(twoFactorInput.Trim());

            if (success)
            {
                showSignInModal = false;
                passwordInput = null;
                twoFactorInput = null;
                await AlertService.ShowToastAsync($"Signed in as {appleIdInput}");
                // Start pending download
                if (pendingDownloadRelease != null)
                {
                    var release = pendingDownloadRelease;
                    pendingDownloadRelease = null;
                    StateHasChanged();
                    await StartDownloadAsync(release);
                }
            }
            else
            {
                signInError = "Invalid verification code. Please try again.";
                twoFactorInput = null;
            }
        }
        catch (Exception ex)
        {
            signInError = $"Verification failed: {ex.Message}";
        }
        finally
        {
            isSigningIn = false;
            StateHasChanged();
        }
    }

    private void SignOut()
    {
        ViewModel.SignOut();
        StateHasChanged();
    }

    private void OpenUrl(string url)
    {
        try
        {
            var psi = new System.Diagnostics.ProcessStartInfo("open", url) { UseShellExecute = false };
            System.Diagnostics.Process.Start(psi);
        }
        catch { }
    }
}
