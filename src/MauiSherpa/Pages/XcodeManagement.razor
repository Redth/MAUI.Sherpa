@page "/xcode-management"
@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Core.ViewModels
@using MauiSherpa.Pages.Forms
@using MauiSherpa.Pages.Modals
@inject XcodeManagementViewModel ViewModel
@inject IPlatformService Platform
@inject IAlertService AlertService
@inject IFormModalService FormModalService
@inject HybridFormBridgeHolder BridgeHolder
@inject IXcodeService XcodeService
@inject ISimulatorService SimulatorService

<h1><i class="fab fa-apple"></i> @ViewModel.Title</h1>

@if (!Platform.IsMacCatalyst && !Platform.IsMacOS)
{
    <div class="not-supported">
        <div class="warning-icon"><i class="fas fa-exclamation-triangle"></i></div>
        <h2>macOS Only</h2>
        <p>Apple development tools management requires macOS with Xcode installed.</p>
    </div>
}
else
{
    <div class="status-bar">
        <span class="status-label">Status:</span>
        <span class="status-text">@ViewModel.StatusMessage</span>
        @if (ViewModel.IsAuthenticated)
        {
            <span class="auth-status signed-in">
                <i class="fas fa-lock"></i> @ViewModel.AuthenticatedAppleId
                <button class="btn-link" @onclick="SignOut">Sign Out</button>
            </span>
        }
        else
        {
            <span class="auth-status">
                <i class="fas fa-lock-open"></i>
                <button class="btn-link" @onclick="OpenAuthModal">Sign In for Downloads</button>
            </span>
        }
    </div>

    <div class="toolbar">
        <button class="btn btn-primary" @onclick="RefreshAll" disabled="@ViewModel.IsLoading">
            <i class="fas fa-sync-alt"></i> @(ViewModel.IsLoading ? "Loading..." : "Refresh")
        </button>
    </div>

    <div class="tabs">
        <button class="tab @(activeTab == "installed" ? "active" : "")" @onclick="@(() => SwitchTab("installed"))">
            <i class="fas fa-hdd"></i> Installed (@ViewModel.InstalledXcodes.Count)
        </button>
        <button class="tab @(activeTab == "available" ? "active" : "")" @onclick="@(() => SwitchTab("available"))">
            <i class="fas fa-cloud-download-alt"></i> Available
            @if (ViewModel.AvailableReleases.Count > 0)
            {
                <span class="tab-count">(@filteredReleases.Count)</span>
            }
        </button>
        <button class="tab @(activeTab == "runtimes" ? "active" : "")" @onclick="@(() => SwitchTab("runtimes"))">
            <i class="fas fa-mobile-alt"></i> Runtimes
            @if (ViewModel.RuntimeStorage.Count > 0)
            {
                <span class="tab-count">(@ViewModel.RuntimeStorage.Count)</span>
            }
        </button>
    </div>

    @* ====== INSTALLED TAB ====== *@
    @if (activeTab == "installed")
    {
        @if (ViewModel.IsLoading && ViewModel.InstalledXcodes.Count == 0)
        {
            <div class="loading-state">
                <div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>
                <div class="loading-title">Discovering Xcode Installations</div>
                <div class="loading-description">Scanning /Applications for Xcode bundles...</div>
            </div>
        }
        else if (ViewModel.InstalledXcodes.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-box-open"></i></div>
                <h3>No Xcode Installations Found</h3>
                <p>Install Xcode from the Mac App Store or download from the Available tab.</p>
            </div>
        }
        else
        {
            <div class="xcode-list">
                @foreach (var xcode in ViewModel.InstalledXcodes)
                {
                    <div class="xcode-card @(xcode.IsSelected ? "selected" : "")">
                        <div class="xcode-card-icon">
                            <i class="fas fa-hammer"></i>
                        </div>
                        <div class="xcode-card-info">
                            <div class="xcode-card-title">
                                Xcode @xcode.Version
                                @if (xcode.IsSelected)
                                {
                                    <span class="badge badge-active"><i class="fas fa-check"></i> Active</span>
                                }
                            </div>
                            <div class="xcode-card-details">
                                <span class="detail-item"><i class="fas fa-code-branch"></i> Build @xcode.BuildNumber</span>
                                <span class="detail-item"><i class="fas fa-folder"></i> @xcode.Path</span>
                            </div>
                        </div>
                        <div class="xcode-card-actions">
                            @if (!xcode.IsSelected)
                            {
                                <button class="btn btn-sm btn-outline" @onclick="() => SelectXcode(xcode)">
                                    <i class="fas fa-check-circle"></i> Select
                                </button>
                                <button class="btn btn-sm btn-danger-outline" @onclick="() => UninstallXcode(xcode)">
                                    <i class="fas fa-trash-alt"></i> Uninstall
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }

    @* ====== AVAILABLE TAB ====== *@
    @if (activeTab == "available")
    {
        <div class="available-controls">
            <label class="toggle-label">
                <input type="checkbox" @bind="showBetas" @bind:event="oninput" />
                <span>Show Betas &amp; RCs</span>
            </label>
            @if (!ViewModel.IsAuthenticated)
            {
                <span class="auth-hint">
                    <i class="fas fa-info-circle"></i> Sign in with Apple ID to download Xcode
                </span>
            }
            @if (ViewModel.IsLoadingAvailable)
            {
                <span class="loading-indicator"><i class="fas fa-spinner fa-spin"></i> Fetching releases...</span>
            }
        </div>

        @if (ViewModel.IsLoadingAvailable && filteredReleases.Count == 0)
        {
            <div class="loading-state">
                <div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>
                <div class="loading-title">Fetching Available Releases</div>
                <div class="loading-description">Querying xcodereleases.com...</div>
            </div>
        }
        else if (filteredReleases.Count > 0)
        {
            <div class="results-info">Showing @filteredReleases.Count releases</div>
            <div class="xcode-list">
                @foreach (var release in filteredReleases)
                {
                    var installed = ViewModel.IsInstalled(release);
                    var isDownloading = downloadingRelease?.Version == release.Version;
                    <div class="xcode-card @(installed ? "installed" : "") @(isDownloading ? "downloading" : "")">
                        <div class="xcode-card-icon">
                            @if (release.IsBeta)
                            {
                                <i class="fas fa-flask"></i>
                            }
                            else
                            {
                                <i class="fas fa-hammer"></i>
                            }
                        </div>
                        <div class="xcode-card-info">
                            <div class="xcode-card-title">
                                Xcode @release.Version
                                @if (release.IsBeta)
                                {
                                    <span class="badge badge-beta">Beta</span>
                                }
                                @if (installed)
                                {
                                    <span class="badge badge-installed"><i class="fas fa-check"></i> Installed</span>
                                }
                            </div>
                            <div class="xcode-card-details">
                                <span class="detail-item"><i class="fas fa-code-branch"></i> Build @release.BuildNumber</span>
                                <span class="detail-item"><i class="fas fa-calendar"></i> @release.ReleaseDate.ToString("MMM d, yyyy")</span>
                                @if (!string.IsNullOrEmpty(release.MinimumMacOSVersion))
                                {
                                    <span class="detail-item"><i class="fas fa-desktop"></i> macOS @release.MinimumMacOSVersion+</span>
                                }
                                @if (release.FileSizeBytes > 0)
                                {
                                    <span class="detail-item"><i class="fas fa-weight"></i> @FormatBytes(release.FileSizeBytes.Value)</span>
                                }
                            </div>
                            @if (release.Sdks.Count > 0)
                            {
                                <div class="xcode-card-sdks">
                                    @foreach (var sdk in release.Sdks.Take(5))
                                    {
                                        <span class="sdk-tag">@sdk.Name @sdk.Version</span>
                                    }
                                    @if (release.Sdks.Count > 5)
                                    {
                                        <span class="sdk-tag more">+@(release.Sdks.Count - 5) more</span>
                                    }
                                </div>
                            }
                            @if (release.Compilers.Count > 0)
                            {
                                <div class="xcode-card-compilers">
                                    @foreach (var compiler in release.Compilers)
                                    {
                                        <span class="compiler-tag">@compiler.Name @compiler.Version</span>
                                    }
                                </div>
                            }
                            @if (isDownloading && downloadProgress != null)
                            {
                                <div class="download-progress">
                                    <div class="progress-bar">
                                        <div class="progress-fill" style="width: @(downloadProgressPercent)%"></div>
                                    </div>
                                    <div class="progress-details">
                                        <span>@FormatBytes(downloadProgress.BytesReceived) / @(downloadProgress.TotalBytes.HasValue ? FormatBytes(downloadProgress.TotalBytes.Value) : "?")</span>
                                        <span>@FormatSpeed(downloadProgress.BytesPerSecond)</span>
                                        @if (downloadProgress.EstimatedTimeRemaining.HasValue)
                                        {
                                            <span>ETA: @FormatTimeSpan(downloadProgress.EstimatedTimeRemaining.Value)</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="xcode-card-actions">
                            @if (!string.IsNullOrEmpty(release.ReleaseNotesUrl))
                            {
                                <button class="btn btn-sm btn-ghost" @onclick="() => OpenUrl(release.ReleaseNotesUrl)" title="Release Notes">
                                    <i class="fas fa-file-alt"></i>
                                </button>
                            }
                            @if (!installed && !string.IsNullOrEmpty(release.DownloadUrl))
                            {
                                @if (isDownloading)
                                {
                                    <button class="btn btn-sm btn-danger-outline" @onclick="CancelDownload">
                                        <i class="fas fa-times"></i> Cancel
                                    </button>
                                }
                                else if (ViewModel.IsAuthenticated)
                                {
                                    <button class="btn btn-sm btn-primary-sm" @onclick="() => DownloadAndInstall(release)" disabled="@(downloadingRelease != null)">
                                        <i class="fas fa-download"></i> Install
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline" @onclick="() => OpenUrl(release.DownloadUrl)" title="Open in browser">
                                        <i class="fas fa-external-link-alt"></i>
                                    </button>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }

    @* ====== RUNTIMES TAB ====== *@
    @if (activeTab == "runtimes")
    {
        @if (ViewModel.IsLoadingRuntimes && ViewModel.RuntimeStorage.Count == 0)
        {
            <div class="loading-state">
                <div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>
                <div class="loading-title">Loading Simulator Runtimes</div>
                <div class="loading-description">Querying simctl for runtime storage info...</div>
            </div>
        }
        else if (ViewModel.RuntimeStorage.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-mobile-alt"></i></div>
                <h3>No Simulator Runtimes Found</h3>
                <p>Install simulator runtimes through Xcode or by adding a .dmg file.</p>
            </div>
        }
        else
        {
            <div class="runtime-summary">
                <i class="fas fa-database"></i>
                Total runtime storage: <strong>@FormatBytes(ViewModel.TotalRuntimeStorageBytes)</strong>
                across @ViewModel.RuntimeStorage.Count runtime(s)
            </div>
            <div class="xcode-list">
                @foreach (var runtime in ViewModel.RuntimeStorage.OrderBy(r => r.PlatformIdentifier).ThenByDescending(r => r.Build))
                {
                    <div class="xcode-card runtime-card">
                        <div class="xcode-card-icon">
                            @if (runtime.PlatformIdentifier?.Contains("iOS") == true)
                            {
                                <i class="fas fa-mobile-alt"></i>
                            }
                            else if (runtime.PlatformIdentifier?.Contains("watchOS") == true)
                            {
                                <i class="fas fa-clock"></i>
                            }
                            else if (runtime.PlatformIdentifier?.Contains("tvOS") == true)
                            {
                                <i class="fas fa-tv"></i>
                            }
                            else if (runtime.PlatformIdentifier?.Contains("visionOS") == true)
                            {
                                <i class="fas fa-vr-cardboard"></i>
                            }
                            else
                            {
                                <i class="fas fa-microchip"></i>
                            }
                        </div>
                        <div class="xcode-card-info">
                            <div class="xcode-card-title">
                                @FormatRuntimeName(runtime)
                                <span class="badge @GetRuntimeStateBadgeClass(runtime.State)">@runtime.State</span>
                            </div>
                            <div class="xcode-card-details">
                                <span class="detail-item"><i class="fas fa-code-branch"></i> Build @(runtime.Build ?? "Unknown")</span>
                                @if (runtime.SizeBytes.HasValue)
                                {
                                    <span class="detail-item"><i class="fas fa-database"></i> @FormatBytes(runtime.SizeBytes.Value)</span>
                                }
                                @if (runtime.LastUsedAt.HasValue)
                                {
                                    <span class="detail-item"><i class="fas fa-clock"></i> Last used @runtime.LastUsedAt.Value.ToString("MMM d, yyyy")</span>
                                }
                                @if (!string.IsNullOrEmpty(runtime.MountPath))
                                {
                                    <span class="detail-item"><i class="fas fa-folder"></i> @runtime.MountPath</span>
                                }
                            </div>
                        </div>
                        <div class="xcode-card-actions">
                            @if (runtime.Deletable)
                            {
                                <button class="btn btn-sm btn-danger-outline" @onclick="() => DeleteRuntime(runtime)" disabled="@deletingRuntime">
                                    <i class="fas fa-trash-alt"></i> Delete
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }

    @* ====== DOWNLOAD/INSTALL MODAL ====== *@
    @if (showInstallModal)
    {
        <div class="modal-overlay">
            <div class="modal modal-wide">
                <div class="modal-header">
                    <h3><i class="fas fa-download"></i> Installing Xcode @downloadingRelease?.Version</h3>
                </div>
                <div class="modal-body">
                    <div class="install-steps">
                        <div class="install-step @GetStepClass(InstallStep.Download)">
                            <div class="step-icon">
                                @if (currentInstallStep == InstallStep.Download)
                                {
                                    <i class="fas fa-spinner fa-spin"></i>
                                }
                                else if (currentInstallStep > InstallStep.Download)
                                {
                                    <i class="fas fa-check-circle text-success"></i>
                                }
                                else
                                {
                                    <i class="fas fa-circle"></i>
                                }
                            </div>
                            <div class="step-content">
                                <div class="step-title">Download</div>
                                @if (currentInstallStep == InstallStep.Download && downloadProgress != null)
                                {
                                    <div class="progress-bar">
                                        <div class="progress-fill" style="width: @(downloadProgressPercent)%"></div>
                                    </div>
                                    <div class="step-detail">
                                        @FormatBytes(downloadProgress.BytesReceived) / @(downloadProgress.TotalBytes.HasValue ? FormatBytes(downloadProgress.TotalBytes.Value) : "?")
                                        — @FormatSpeed(downloadProgress.BytesPerSecond)
                                        @if (downloadProgress.EstimatedTimeRemaining.HasValue)
                                        {
                                            <text> — ETA: @FormatTimeSpan(downloadProgress.EstimatedTimeRemaining.Value)</text>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="install-step @GetStepClass(InstallStep.Extract)">
                            <div class="step-icon">
                                @if (currentInstallStep == InstallStep.Extract)
                                {
                                    <i class="fas fa-spinner fa-spin"></i>
                                }
                                else if (currentInstallStep > InstallStep.Extract)
                                {
                                    <i class="fas fa-check-circle text-success"></i>
                                }
                                else
                                {
                                    <i class="fas fa-circle"></i>
                                }
                            </div>
                            <div class="step-content">
                                <div class="step-title">Extract &amp; Install</div>
                                @if (currentInstallStep == InstallStep.Extract && !string.IsNullOrEmpty(installStepMessage))
                                {
                                    <div class="step-detail">@installStepMessage</div>
                                }
                            </div>
                        </div>
                        <div class="install-step @GetStepClass(InstallStep.FirstLaunch)">
                            <div class="step-icon">
                                @if (currentInstallStep == InstallStep.FirstLaunch)
                                {
                                    <i class="fas fa-spinner fa-spin"></i>
                                }
                                else if (currentInstallStep > InstallStep.FirstLaunch)
                                {
                                    <i class="fas fa-check-circle text-success"></i>
                                }
                                else
                                {
                                    <i class="fas fa-circle"></i>
                                }
                            </div>
                            <div class="step-content">
                                <div class="step-title">First Launch Setup</div>
                                @if (currentInstallStep == InstallStep.FirstLaunch && !string.IsNullOrEmpty(installStepMessage))
                                {
                                    <div class="step-detail">@installStepMessage</div>
                                }
                            </div>
                        </div>
                        <div class="install-step @GetStepClass(InstallStep.Complete)">
                            <div class="step-icon">
                                @if (currentInstallStep >= InstallStep.Complete)
                                {
                                    <i class="fas fa-check-circle text-success"></i>
                                }
                                else
                                {
                                    <i class="fas fa-circle"></i>
                                }
                            </div>
                            <div class="step-content">
                                <div class="step-title">Complete</div>
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(installError))
                    {
                        <div class="auth-error" style="margin-top: 1rem;"><i class="fas fa-exclamation-circle"></i> @installError</div>
                    }
                </div>
                <div class="modal-footer">
                    @if (currentInstallStep >= InstallStep.Complete || !string.IsNullOrEmpty(installError))
                    {
                        <button class="btn btn-primary" @onclick="CloseInstallModal">Done</button>
                    }
                    else
                    {
                        <button class="btn btn-danger-outline" @onclick="CancelDownload">Cancel</button>
                    }
                </div>
            </div>
        </div>
    }
}

<style>
    h1 {
        margin-bottom: 1.25rem;
        font-size: 1.75rem;
        color: var(--text-primary);
    }

    .not-supported {
        text-align: center;
        padding: 3.75rem 1.25rem;
        background: var(--status-error-bg);
        border-radius: 0.75rem;
        border: 1px solid var(--accent-danger);
    }
    .not-supported .warning-icon { font-size: 48px; margin-bottom: 1rem; color: var(--accent-warning); }
    .not-supported .warning-icon i { font-size: 48px; }
    .not-supported h2 { color: var(--accent-danger); margin-bottom: 0.5rem; }
    .not-supported p { color: var(--text-muted); }

    .status-bar {
        background: var(--card-bg);
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1rem;
        border: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .status-label { font-weight: 600; color: var(--text-primary); }
    .status-text { color: var(--text-secondary); flex: 1; }

    .auth-status {
        font-size: 0.8125rem;
        display: flex;
        align-items: center;
        gap: 0.375rem;
        margin-left: auto;
    }
    .auth-status.signed-in { color: var(--accent-success); }
    .auth-status .btn-link {
        background: none;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 0.75rem;
        text-decoration: underline;
        padding: 0;
    }
    .auth-status .btn-link:hover { color: var(--accent-danger); }

    .auth-hint {
        font-size: 0.75rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.375rem;
    }

    .toolbar {
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Tabs */
    .tabs {
        display: flex;
        gap: 0.25rem;
        margin-bottom: 1rem;
        border-bottom: 2px solid var(--border-color);
    }
    .tab {
        padding: 0.75rem 1.25rem;
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--text-muted);
        font-size: 0.875rem;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .tab:hover { color: var(--accent-primary); }
    .tab.active {
        color: var(--accent-primary);
        border-bottom-color: var(--accent-primary);
        font-weight: 600;
    }
    .tab-count { opacity: 0.7; }

    /* Loading & Empty States */
    .loading-state, .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        background: var(--card-bg);
        border-radius: var(--card-radius);
        border: 1px solid var(--border-color);
    }
    .loading-spinner { font-size: 2rem; color: var(--accent-primary); margin-bottom: 1rem; }
    .loading-title, .empty-state h3 { font-size: 1.125rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; }
    .loading-description, .empty-state p { color: var(--text-muted); font-size: 0.875rem; }
    .empty-icon { font-size: 2.5rem; color: var(--text-muted); margin-bottom: 1rem; opacity: 0.5; }

    /* Xcode Cards */
    .xcode-list { display: flex; flex-direction: column; gap: 0.5rem; }

    .xcode-card {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--card-radius);
        transition: all 0.15s ease;
    }
    .xcode-card:hover { border-color: var(--accent-primary); box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .xcode-card.selected { border-color: var(--accent-success); background: var(--status-success-bg); }
    .xcode-card.installed { border-left: 3px solid var(--accent-success); }
    .xcode-card.downloading { border-color: var(--accent-primary); background: rgba(66, 153, 225, 0.03); }

    .xcode-card-icon {
        font-size: 1.5rem;
        color: var(--accent-primary);
        padding-top: 0.125rem;
        flex-shrink: 0;
        width: 2rem;
        text-align: center;
    }
    .xcode-card.selected .xcode-card-icon { color: var(--accent-success); }

    .xcode-card-info { flex: 1; min-width: 0; }

    .xcode-card-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .xcode-card-details {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 0.375rem;
        font-size: 0.8125rem;
        color: var(--text-muted);
    }
    .detail-item { display: flex; align-items: center; gap: 0.375rem; }
    .detail-item i { font-size: 0.6875rem; opacity: 0.7; }

    .xcode-card-sdks, .xcode-card-compilers {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        margin-top: 0.5rem;
    }

    .sdk-tag {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        font-size: 0.6875rem;
        border-radius: 0.25rem;
        background: var(--bg-tertiary);
        color: var(--text-secondary);
        border: 1px solid var(--border-color);
    }
    .sdk-tag.more { font-style: italic; opacity: 0.7; }

    .compiler-tag {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        font-size: 0.6875rem;
        border-radius: 0.25rem;
        background: rgba(66, 153, 225, 0.1);
        color: var(--accent-primary);
        border: 1px solid rgba(66, 153, 225, 0.2);
    }

    .xcode-card-actions {
        display: flex;
        gap: 0.375rem;
        flex-shrink: 0;
        align-items: flex-start;
    }

    /* Badges */
    .badge {
