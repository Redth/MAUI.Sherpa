</style>

@code {
    private string activeTab = "installed";
    private bool showBetas;
    private bool hasInitialized;

    // Download/Install state
    private XcodeRelease? downloadingRelease;
    private XcodeDownloadProgress? downloadProgress;
    private CancellationTokenSource? downloadCts;
    private bool showInstallModal;
    private InstallStep currentInstallStep = InstallStep.Download;
    private string? installStepMessage;
    private string? installError;

    // Runtime state
    private bool deletingRuntime;

    private enum InstallStep { Download, Extract, FirstLaunch, Complete }

    private double downloadProgressPercent =>
        downloadProgress?.TotalBytes > 0
            ? (double)downloadProgress.BytesReceived / downloadProgress.TotalBytes.Value * 100
            : 0;

    private IReadOnlyList<XcodeRelease> filteredReleases =>
        showBetas
            ? ViewModel.AvailableReleases.Take(50).ToList()
            : ViewModel.AvailableReleases.Where(r => !r.IsBeta).Take(50).ToList();

    protected override async Task OnInitializedAsync()
    {
        if (!hasInitialized)
        {
            hasInitialized = true;
            await ViewModel.LoadInstalledAsync();
        }
    }

    private async Task RefreshAll()
    {
        if (activeTab == "installed")
            await ViewModel.LoadInstalledAsync();
        else if (activeTab == "available")
            await ViewModel.LoadAvailableAsync();
        else if (activeTab == "runtimes")
            await ViewModel.LoadRuntimeStorageAsync();
    }

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        if (tab == "available" && ViewModel.AvailableReleases.Count == 0)
            await ViewModel.LoadAvailableAsync();
        else if (tab == "runtimes" && ViewModel.RuntimeStorage.Count == 0)
            await ViewModel.LoadRuntimeStorageAsync();
    }

    private async Task SelectXcode(XcodeInstallation xcode)
    {
        await ViewModel.SelectXcodeAsync(xcode);
        StateHasChanged();
    }

    private async Task UninstallXcode(XcodeInstallation xcode)
    {
        await ViewModel.UninstallXcodeAsync(xcode);
        StateHasChanged();
    }

    private async Task OpenAuthModal()
    {
        var result = await FormModalService.ShowAsync<bool>(new XcodeDownloadAuthPage(BridgeHolder));
        StateHasChanged();

        if (result == true)
            await AlertService.ShowToastAsync("Signed in to Apple Developer");
    }

    private async Task SignOut()
    {
        var confirmed = await AlertService.ShowConfirmAsync(
            "Sign Out", "Sign out of Apple Developer? You'll need to sign in again to download Xcode.", "Sign Out", "Cancel");
        if (confirmed)
        {
            await ViewModel.SignOutAsync();
            StateHasChanged();
        }
    }

    // ---- Download & Install ----
    private async Task DownloadAndInstall(XcodeRelease release)
    {
        if (downloadingRelease != null) return;

        downloadingRelease = release;
        downloadProgress = null;
        downloadCts = new CancellationTokenSource();
        showInstallModal = true;
        currentInstallStep = InstallStep.Download;
        installStepMessage = null;
        installError = null;
        StateHasChanged();

        try
        {
            var tempPath = Path.Combine(Path.GetTempPath(), $"Xcode_{release.Version}_{release.BuildNumber}.xip");
            var progress = new Progress<XcodeDownloadProgress>(p =>
            {
                downloadProgress = p;
                InvokeAsync(StateHasChanged);
            });

            var downloadOk = await XcodeService.DownloadXcodeAsync(release, tempPath, progress, downloadCts.Token);
            if (!downloadOk)
            {
                installError = "Download failed. You may need to sign in again.";
                return;
            }

            currentInstallStep = InstallStep.Extract;
            installStepMessage = "Extracting and moving to /Applications...";
            StateHasChanged();

            var installProgress = new Progress<string>(msg =>
            {
                installStepMessage = msg;
                if (msg.Contains("first launch", StringComparison.OrdinalIgnoreCase))
                    currentInstallStep = InstallStep.FirstLaunch;
                InvokeAsync(StateHasChanged);
            });

            var installOk = await XcodeService.InstallXcodeAsync(tempPath, null, installProgress, downloadCts.Token);
            if (!installOk)
            {
                installError = "Installation failed. The Xcode .xip file has been preserved in your temp directory.";
                return;
            }

            currentInstallStep = InstallStep.Complete;
            installStepMessage = null;
            await ViewModel.LoadInstalledAsync();
        }
        catch (OperationCanceledException)
        {
            installError = "Installation cancelled.";
        }
        catch (Exception ex)
        {
            installError = $"Error: {ex.Message}";
        }
        finally
        {
            downloadingRelease = null;
            downloadProgress = null;
            downloadCts?.Dispose();
            downloadCts = null;
            StateHasChanged();
        }
    }

    private void CancelDownload()
    {
        downloadCts?.Cancel();
    }

    private void CloseInstallModal()
    {
        showInstallModal = false;
        downloadingRelease = null;
        downloadProgress = null;
        installError = null;
        StateHasChanged();
    }

    // ---- Runtimes ----
    private async Task DeleteRuntime(SimulatorRuntimeStorage runtime)
    {
        var confirmed = await AlertService.ShowConfirmAsync(
            "Delete Runtime",
            $"Delete {FormatRuntimeName(runtime)}?\n\nThis will free {(runtime.SizeBytes.HasValue ? FormatBytes(runtime.SizeBytes.Value) : "some")} of disk space. This cannot be undone.",
            "Delete",
            "Cancel");

        if (!confirmed) return;

        deletingRuntime = true;
        StateHasChanged();

        try
        {
            var success = await SimulatorService.DeleteRuntimeAsync(runtime.Identifier);
            if (success)
            {
                await ViewModel.LoadRuntimeStorageAsync();
                await AlertService.ShowToastAsync("Runtime deleted");
            }
            else
            {
                await AlertService.ShowAlertAsync("Error", "Failed to delete runtime.");
            }
        }
        catch (Exception ex)
        {
            await AlertService.ShowAlertAsync("Error", $"Failed to delete runtime: {ex.Message}");
        }
        finally
        {
            deletingRuntime = false;
            StateHasChanged();
        }
    }

    // ---- Helpers ----
    private void OpenUrl(string url)
    {
        try
        {
            var psi = new System.Diagnostics.ProcessStartInfo("open", url) { UseShellExecute = false };
            System.Diagnostics.Process.Start(psi);
        }
        catch { }
    }

    private string GetStepClass(InstallStep step)
    {
        if (currentInstallStep == step) return "active";
        if (currentInstallStep > step) return "completed";
        return "";
    }

    private string GetRuntimeStateBadgeClass(string state) => state.ToLowerInvariant() switch
    {
        "ready" => "badge-ready",
        "booted" => "badge-booted",
        _ => "badge-unknown"
    };

    private static string FormatRuntimeName(SimulatorRuntimeStorage runtime)
    {
        if (!string.IsNullOrEmpty(runtime.PlatformIdentifier))
        {
            var parts = runtime.PlatformIdentifier.Split('.');
            var platform = parts.Length > 0 ? parts[^1] : runtime.PlatformIdentifier;
            return $"{platform} (Build {runtime.Build ?? "Unknown"})";
        }
        return $"Runtime {runtime.Identifier}";
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }

    private static string FormatSpeed(double bytesPerSecond)
    {
        if (bytesPerSecond < 1024) return $"{bytesPerSecond:F0} B/s";
        if (bytesPerSecond < 1024 * 1024) return $"{bytesPerSecond / 1024:F1} KB/s";
        return $"{bytesPerSecond / (1024 * 1024):F1} MB/s";
    }

    private static string FormatTimeSpan(TimeSpan ts)
    {
        if (ts.TotalHours >= 1) return $"{ts.Hours}h {ts.Minutes}m";
        if (ts.TotalMinutes >= 1) return $"{ts.Minutes}m {ts.Seconds}s";
        return $"{ts.Seconds}s";
    }
}
