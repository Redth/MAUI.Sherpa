@code {
    private string activeTab = "installed";
    private string searchQuery = "";
    private bool showBetas;
    private bool hasInitialized;
    private bool hasLoadedRuntimeData;

    // Download/Install state
    private XcodeRelease? downloadingRelease;
    private XcodeDownloadProgress? downloadProgress;
    private CancellationTokenSource? downloadCts;
    private bool showInstallModal;
    private InstallStep currentInstallStep = InstallStep.Download;
    private string? installStepMessage;
    private string? installError;

    // Runtime state
    private string? installingDownloadableRuntimeBuild;

    private enum InstallStep { Download, Extract, FirstLaunch, Complete }

    private double downloadProgressPercent =>
        downloadProgress?.TotalBytes > 0
            ? (double)downloadProgress.BytesReceived / downloadProgress.TotalBytes.Value * 100
            : 0;

    private IReadOnlyList<XcodeInstallation> filteredInstalledXcodes =>
        ViewModel.InstalledXcodes
            .Where(MatchesSearch)
            .ToList();

    private IReadOnlyList<XcodeRelease> filteredReleases =>
        ViewModel.AvailableReleases
            .Where(r => showBetas || !r.IsBeta)
            .Where(MatchesSearch)
            .Take(50)
            .ToList();

    private IReadOnlyList<SimulatorRuntimeStorage> filteredRuntimeStorage =>
        ViewModel.RuntimeStorage
            .Where(MatchesSearch)
            .ToList();

    private IReadOnlyList<DownloadableSimulatorRuntime> downloadableRuntimeCatalog =>
        ViewModel.DownloadableRuntimes
            .Where(IsModernDownloadableRuntime)
            .OrderBy(runtime => GetPlatformSortOrder(runtime.PlatformIdentifier))
            .ThenByDescending(runtime => ParseComparableVersion(runtime.Version))
            .ThenByDescending(runtime => runtime.Build, StringComparer.OrdinalIgnoreCase)
            .ThenBy(runtime => runtime.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private long filteredRuntimeStorageBytes =>
        filteredRuntimeStorage
            .Where(runtime => runtime.SizeBytes.HasValue)
            .Sum(runtime => runtime.SizeBytes!.Value);

    private bool IsActiveTabLoading => activeTab switch
    {
        "available" => ViewModel.IsLoadingAvailable,
        "runtimes" => ViewModel.IsLoadingRuntimes || ViewModel.IsLoadingDownloadableRuntimes,
        _ => ViewModel.IsLoading,
    };

    protected override async Task OnInitializedAsync()
    {
        if (!hasInitialized)
        {
            hasInitialized = true;
            DownloadAuthService.AuthStateChanged += OnDownloadAuthStateChanged;
            ToolbarService.ClearItems();
            ToolbarService.SetItems(
                new ToolbarAction("refresh", "Refresh", "arrow.clockwise")
            );
            ToolbarService.SetSearch("Search Xcode versions or runtimes...");
            ToolbarService.SetFilters();
            ToolbarService.ToolbarItemClicked += OnToolbarItemClicked;
            ToolbarService.SearchTextChanged += OnSearchTextChanged;
            await ViewModel.LoadInstalledAsync();
        }
    }

    private void OnToolbarItemClicked(string actionId)
    {
        if (actionId != "refresh")
            return;

        InvokeAsync(async () =>
        {
            ToolbarService.SetItemEnabled("refresh", false);
            try
            {
                await RefreshAll();
            }
            finally
            {
                ToolbarService.SetItemEnabled("refresh", true);
                StateHasChanged();
            }
        });
    }

    private void OnSearchTextChanged(string text)
    {
        InvokeAsync(() =>
        {
            searchQuery = text;
            StateHasChanged();
        });
    }

    private void OnDownloadAuthStateChanged() =>
        InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        DownloadAuthService.AuthStateChanged -= OnDownloadAuthStateChanged;
        ToolbarService.ToolbarItemClicked -= OnToolbarItemClicked;
        ToolbarService.SearchTextChanged -= OnSearchTextChanged;
    }

    private async Task RefreshAll()
    {
        if (activeTab == "installed")
        {
            await Mediator.FlushStores("apple:xcode:installed");
            await ViewModel.LoadInstalledAsync();
        }
        else if (activeTab == "available")
        {
            await Mediator.FlushStores("apple:xcode:available");
            await ViewModel.LoadAvailableAsync();
        }
        else if (activeTab == "runtimes")
            await LoadRuntimeDataAsync(forceRefresh: true);
    }

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        if (tab == "available" && ViewModel.AvailableReleases.Count == 0)
            await ViewModel.LoadAvailableAsync();
        else if (tab == "runtimes" && !hasLoadedRuntimeData)
            await LoadRuntimeDataAsync();

        StateHasChanged();
    }

    private bool MatchesSearch(XcodeInstallation xcode) =>
        ContainsSearchText(xcode.Version, xcode.BuildNumber, xcode.Path);

    private bool MatchesSearch(XcodeRelease release)
    {
        if (ContainsSearchText(release.Version, release.BuildNumber, release.MinimumMacOSVersion))
            return true;

        return release.Sdks.Any(sdk => ContainsSearchText(sdk.Name, sdk.Version)) ||
               release.Compilers.Any(compiler => ContainsSearchText(compiler.Name, compiler.Version));
    }

    private bool MatchesSearch(SimulatorRuntimeStorage runtime) =>
        ContainsSearchText(
            FormatRuntimeName(runtime),
            FriendlyPlatform(runtime.PlatformIdentifier),
            runtime.Identifier,
            runtime.Build,
            runtime.State,
            runtime.MountPath);

    private bool ContainsSearchText(params string?[] values)
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
            return true;

        var trimmedQuery = searchQuery.Trim();
        return values.Any(value =>
            !string.IsNullOrWhiteSpace(value) &&
            value.Contains(trimmedQuery, StringComparison.OrdinalIgnoreCase));
    }

    private async Task SelectXcode(XcodeInstallation xcode)
    {
        await ViewModel.SelectXcodeAsync(xcode);
        StateHasChanged();
    }

    private async Task UninstallXcode(XcodeInstallation xcode)
    {
        await ViewModel.UninstallXcodeAsync(xcode);
        StateHasChanged();
    }

    private async Task OpenAuthModal()
    {
        var result = await FormModalService.ShowAsync<bool>(new XcodeDownloadAuthPage(BridgeHolder));
        StateHasChanged();

        if (result == true)
            await AlertService.ShowToastAsync("Signed in to Apple Developer");
    }

    private async Task SignOut()
    {
        var confirmed = await AlertService.ShowConfirmAsync(
            "Sign Out", "Sign out of Apple Developer? You'll need to sign in again to download Xcode.", "Sign Out", "Cancel");
        if (confirmed)
        {
            await ViewModel.SignOutAsync();
            StateHasChanged();
        }
    }

    // ---- Download & Install ----
    private async Task DownloadAndInstall(XcodeRelease release)
    {
        if (downloadingRelease != null) return;

        downloadingRelease = release;
        downloadProgress = null;
        downloadCts = new CancellationTokenSource();
        showInstallModal = true;
        currentInstallStep = InstallStep.Download;
        installStepMessage = null;
        installError = null;
        StateHasChanged();

        try
        {
            var tempPath = Path.Combine(Path.GetTempPath(), $"Xcode_{release.Version}_{release.BuildNumber}.xip");
            var progress = new Progress<XcodeDownloadProgress>(p =>
            {
                downloadProgress = p;
                InvokeAsync(StateHasChanged);
            });

            var downloadOk = await XcodeService.DownloadXcodeAsync(release, tempPath, progress, downloadCts.Token);
            if (!downloadOk)
            {
                installError = "Download failed. You may need to sign in again.";
                return;
            }

            currentInstallStep = InstallStep.Extract;
            installStepMessage = "Extracting and moving to /Applications...";
            StateHasChanged();

            var installProgress = new Progress<string>(msg =>
            {
                installStepMessage = msg;
                if (msg.Contains("first launch", StringComparison.OrdinalIgnoreCase))
                    currentInstallStep = InstallStep.FirstLaunch;
                InvokeAsync(StateHasChanged);
            });

            var installOk = await XcodeService.InstallXcodeAsync(tempPath, null, installProgress, downloadCts.Token);
            if (!installOk)
            {
                installError = "Installation failed. The Xcode .xip file has been preserved in your temp directory.";
                return;
            }

            currentInstallStep = InstallStep.Complete;
            installStepMessage = null;
            await ViewModel.LoadInstalledAsync();
        }
        catch (OperationCanceledException)
        {
            installError = "Installation cancelled.";
        }
        catch (Exception ex)
        {
            installError = $"Error: {ex.Message}";
        }
        finally
        {
            downloadingRelease = null;
            downloadProgress = null;
            downloadCts?.Dispose();
            downloadCts = null;
            StateHasChanged();
        }
    }

    private void CancelDownload()
    {
        downloadCts?.Cancel();
    }

    private void CloseInstallModal()
    {
        showInstallModal = false;
        downloadingRelease = null;
        downloadProgress = null;
        installError = null;
        StateHasChanged();
    }

    // ---- Runtimes ----
    private async Task DeleteRuntime(SimulatorRuntimeStorage runtime)
    {
        var confirmed = await AlertService.ShowConfirmAsync(
            "Delete Runtime",
            $"Delete {FormatRuntimeName(runtime)}?\n\nThis will free {(runtime.SizeBytes.HasValue ? FormatBytes(runtime.SizeBytes.Value) : "some")} of disk space. This cannot be undone.",
            "Delete",
            "Cancel");

        if (!confirmed) return;

        var runtimeName = FormatRuntimeName(runtime);
        var result = await OperationModal.RunAsync(
            "Delete Runtime",
            $"Deleting {runtimeName}...",
            async ctx =>
            {
                ctx.LogInfo($"Runtime: {runtimeName}");
                ctx.LogInfo($"Delete identifier: {runtime.DeleteIdentifier}");
                ctx.SetStatus("Deleting runtime...");

                var success = await SimulatorService.DeleteRuntimeAsync(
                    runtime.DeleteIdentifier,
                    new Progress<string>(message =>
                    {
                        ctx.LogInfo(message);
                        ctx.SetStatus(message);
                    }));

                if (!success)
                    return false;

                ctx.SetStatus("Refreshing runtime data...");
                ctx.LogInfo("Refreshing installed and downloadable runtimes...");
                await LoadRuntimeDataAsync(forceRefresh: true);
                ctx.LogSuccess("Runtime data refreshed");
                return true;
            },
            canCancel: false);

        if (result.Success)
        {
            await AlertService.ShowToastAsync($"{runtimeName} deleted");
        }
    }

    private async Task LoadRuntimeDataAsync(bool forceRefresh = false)
    {
        if (forceRefresh)
        {
            await Mediator.FlushStores("apple:simulator:runtimes");
            await Mediator.FlushStores("apple:simulator:runtime-storage");
            await Mediator.FlushStores("apple:simulator:downloadable-runtimes");
        }

        await Task.WhenAll(
            ViewModel.LoadRuntimeStorageAsync(),
            ViewModel.LoadDownloadableRuntimesAsync());

        hasLoadedRuntimeData = true;
    }

    private async Task OpenRuntimePicker()
    {
        if (ViewModel.DownloadableRuntimes.Count == 0 && !ViewModel.IsLoadingDownloadableRuntimes)
        {
            await ViewModel.LoadDownloadableRuntimesAsync();
        }

        var selectedRuntime = await FormModalService.ShowAsync<DownloadableSimulatorRuntime?>(
            new RuntimePickerPage(
                BridgeHolder,
                downloadableRuntimeCatalog,
                ViewModel.RuntimeStorage
                    .Where(runtime => !string.IsNullOrWhiteSpace(runtime.Build))
                    .Select(runtime => runtime.Build!)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList()));

        if (selectedRuntime != null)
            await InstallDownloadableRuntime(selectedRuntime);
    }

    private async Task InstallDownloadableRuntime(DownloadableSimulatorRuntime runtime)
    {
        if (installingDownloadableRuntimeBuild != null)
            return;

        installingDownloadableRuntimeBuild = runtime.Build;
        StateHasChanged();

        try
        {
            var result = await ProcessModal.ShowProcessAsync(
                new ProcessRequest(
                    Command: "/usr/bin/xcodebuild",
                    Arguments: ["-downloadPlatform", GetDownloadPlatform(runtime.PlatformIdentifier), "-buildVersion", runtime.Build],
                    RequiresElevation: false,
                    Title: $"Install {FormatDownloadableRuntimeName(runtime)}",
                    Description: $"Download and install {FormatDownloadableRuntimeName(runtime)} using Xcode."
                ));

            if (result?.Success == true)
            {
                await LoadRuntimeDataAsync(forceRefresh: true);
                await AlertService.ShowToastAsync($"{FormatDownloadableRuntimeName(runtime)} installed");
            }
            else if (result != null && !result.WasCancelled && !result.WasKilled)
            {
                await AlertService.ShowAlertAsync("Install Failed", $"Installing {FormatDownloadableRuntimeName(runtime)} failed. Check the process output for details.");
            }
        }
        finally
        {
            installingDownloadableRuntimeBuild = null;
            StateHasChanged();
        }
    }

    // ---- Helpers ----
    private void OpenUrl(string url)
    {
        try
        {
            var psi = new System.Diagnostics.ProcessStartInfo("open", url) { UseShellExecute = false };
            System.Diagnostics.Process.Start(psi);
        }
        catch { }
    }

    private string GetStepClass(InstallStep step)
    {
        if (currentInstallStep == step) return "active";
        if (currentInstallStep > step) return "completed";
        return "";
    }

    private static string GetRuntimeIcon(string? platformIdentifier) => FriendlyPlatform(platformIdentifier) switch
    {
        "iOS" => "fas fa-mobile-alt",
        "watchOS" => "fas fa-clock",
        "tvOS" => "fas fa-tv",
        "visionOS" => "fas fa-vr-cardboard",
        "macOS" => "fas fa-laptop",
        _ => "fas fa-cube"
    };

    private string GetRuntimeStateBadgeClass(string state) => state.ToLowerInvariant() switch
    {
        "ready" => "badge-ready",
        "booted" => "badge-booted",
        _ => "badge-unknown"
    };

    private static bool IsModernDownloadableRuntime(DownloadableSimulatorRuntime runtime) =>
        runtime.ContentType is "cryptexDiskImage" or "patchableCryptexDiskImage";

    private static string FormatRuntimeName(SimulatorRuntimeStorage runtime)
    {
        var parsed = ParseRuntimeLabel(runtime.Identifier);
        if (!string.IsNullOrWhiteSpace(parsed))
            return parsed;

        if (!string.IsNullOrEmpty(runtime.PlatformIdentifier))
        {
            return FriendlyPlatform(runtime.PlatformIdentifier);
        }

        return $"Runtime {runtime.Identifier}";
    }

    private static string FriendlyPlatform(string? platform) => platform switch
    {
        "com.apple.platform.iphonesimulator" or "com.apple.platform.iphoneos" => "iOS",
        "com.apple.platform.watchos" or "com.apple.platform.watchsimulator" => "watchOS",
        "com.apple.platform.tvos" or "com.apple.platform.appletvos" or "com.apple.platform.tvsimulator" or "com.apple.platform.appletvsimulator" => "tvOS",
        "com.apple.platform.xros" or "com.apple.platform.xrsimulator" => "visionOS",
        "com.apple.platform.macosx" => "macOS",
        null or "" => "Unknown Platform",
        _ => platform
    };

    private static string ParseRuntimeLabel(string identifier)
    {
        const string prefix = "com.apple.CoreSimulator.SimRuntime.";
        if (string.IsNullOrWhiteSpace(identifier))
            return string.Empty;

        var trimmed = identifier.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
            ? identifier[prefix.Length..]
            : identifier;

        var firstDash = trimmed.IndexOf('-');
        if (firstDash < 0)
            return trimmed;

        var family = trimmed[..firstDash];
        var version = trimmed[(firstDash + 1)..].Replace('-', '.');
        return $"{family} {version}";
    }

    private static string FormatDownloadableRuntimeName(DownloadableSimulatorRuntime runtime)
    {
        const string suffix = " Simulator Runtime";
        return runtime.Name.EndsWith(suffix, StringComparison.OrdinalIgnoreCase)
            ? runtime.Name[..^suffix.Length]
            : runtime.Name;
    }

    private static string FormatLastUsed(DateTime lastUsedAt) =>
        lastUsedAt.ToLocalTime().ToString("MMM d, yyyy");

    private static string GetDownloadPlatform(string platformIdentifier) => FriendlyPlatform(platformIdentifier) switch
    {
        "iOS" => "iOS",
        "watchOS" => "watchOS",
        "tvOS" => "tvOS",
        "visionOS" => "visionOS",
        _ => throw new InvalidOperationException($"Unsupported runtime platform: {platformIdentifier}")
    };

    private static int GetPlatformSortOrder(string? platformIdentifier) => FriendlyPlatform(platformIdentifier) switch
    {
        "iOS" => 0,
        "watchOS" => 1,
        "tvOS" => 2,
        "visionOS" => 3,
        "macOS" => 4,
        _ => 5
    };

    private static Version ParseComparableVersion(string version)
    {
        if (Version.TryParse(version, out var parsed))
            return parsed;

        var segments = version
            .Split('.', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(segment => int.TryParse(segment, out var value) ? value : 0)
            .Take(4)
            .ToList();

        while (segments.Count < 4)
            segments.Add(0);

        return new Version(segments[0], segments[1], segments[2], segments[3]);
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }

    private static string FormatSpeed(double bytesPerSecond)
    {
        if (bytesPerSecond < 1024) return $"{bytesPerSecond:F0} B/s";
        if (bytesPerSecond < 1024 * 1024) return $"{bytesPerSecond / 1024:F1} KB/s";
        return $"{bytesPerSecond / (1024 * 1024):F1} MB/s";
    }

    private static string FormatTimeSpan(TimeSpan ts)
    {
        if (ts.TotalHours >= 1) return $"{ts.Hours}h {ts.Minutes}m";
        if (ts.TotalMinutes >= 1) return $"{ts.Minutes}m {ts.Seconds}s";
        return $"{ts.Seconds}s";
    }
}
