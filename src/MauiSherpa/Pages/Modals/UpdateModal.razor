@page "/modal/update-available"
@using MauiSherpa.Core.Interfaces
@using Markdig
@inject MauiSherpa.Pages.Forms.ModalParameterService ModalParams
@inject IUpdateService UpdateService
@inject IAlertService AlertService
@inject ILauncher AppLauncher

<div class="dialog-content">
    <div class="dialog-header">
        <h2><i class="fas fa-arrow-up"></i> Update Available</h2>
    </div>

    @if (updateResult?.LatestRelease != null)
    {
        <div class="dialog-body">
            <div class="version-info">
                <div class="version-badge current">
                    <span class="label">Current Version</span>
                    <span class="version">v@(TruncateVersion(updateResult.CurrentVersion))</span>
                </div>
                <span class="version-arrow"><i class="fas fa-arrow-right"></i></span>
                <div class="version-badge new">
                    <span class="label">New Version</span>
                    <span class="version">@(updateResult.LatestRelease.TagName)</span>
                </div>
            </div>

            <div class="release-notes">
                <div class="release-notes-header">
                    <h4>What's New</h4>
                    <span class="release-date">
                        <i class="far fa-calendar"></i>
                        @updateResult.LatestRelease.PublishedAt.ToString("MMM dd, yyyy")
                    </span>
                </div>
                <div class="notes-content">
                    @((MarkupString)ConvertMarkdownToHtml(updateResult.LatestRelease.Body))
                </div>
            </div>
        </div>

        <div class="dialog-footer">
            @if (isUpdating)
            {
                <div class="update-progress">
                    <div class="progress-bar-container">
                        <div class="progress-bar-fill" style="width: @progressPercent.ToString("F0")%"></div>
                    </div>
                    <span class="progress-text">@progressMessage</span>
                </div>
            }
            else if (updateError != null)
            {
                <div class="update-error">
                    <span class="error-text"><i class="fas fa-exclamation-triangle"></i> @updateError</span>
                </div>
                <button class="btn btn-secondary" @onclick="Cancel">Close</button>
            }
            else
            {
                <button class="btn btn-secondary" @onclick="Cancel">
                    <i class="fas fa-times"></i> Not Now
                </button>
                <button class="btn btn-secondary" @onclick="OpenInBrowser">
                    <i class="fas fa-external-link-alt"></i> Download
                </button>
                @if (OperatingSystem.IsMacCatalyst() || OperatingSystem.IsMacOS())
                {
                    <button class="btn btn-primary" @onclick="AutoUpdate">
                        <i class="fas fa-download"></i> Download &amp; Install
                    </button>
                }
            }
        </div>
    }
</div>

@code {
    private UpdateCheckResult? updateResult;
    private bool isUpdating;
    private double progressPercent;
    private string progressMessage = "";
    private string? updateError;

    protected override void OnInitialized()
    {
        updateResult = ModalParams.Get<UpdateCheckResult>("UpdateResult");
    }

    private void Cancel()
    {
        if (updateResult?.LatestRelease != null)
            UpdateService.DismissVersion(updateResult.LatestRelease.TagName);
        ModalParams.Cancel();
    }

    private async Task OpenInBrowser()
    {
        if (updateResult?.LatestRelease?.HtmlUrl is { Length: > 0 } url)
        {
            try { await AppLauncher.OpenAsync(new Uri(url)); } catch { }
        }
        ModalParams.Complete(true);
    }

    private async Task AutoUpdate()
    {
        if (updateResult?.LatestRelease == null) return;

        isUpdating = true;
        updateError = null;
        progressPercent = 0;
        progressMessage = "Preparing...";
        StateHasChanged();

        try
        {
            var progress = new Progress<(double Percent, string Message)>(update =>
            {
                progressPercent = update.Percent;
                progressMessage = update.Message;
                InvokeAsync(StateHasChanged);
            });

            await UpdateService.DownloadAndApplyUpdateAsync(updateResult.LatestRelease, progress);
        }
        catch (Exception ex)
        {
            isUpdating = false;
            updateError = ex.Message;
            StateHasChanged();
        }
    }

    private static string TruncateVersion(string version)
    {
        var plusIndex = version.IndexOf('+');
        if (plusIndex >= 0 && version.Length > plusIndex + 8)
            return version[..(plusIndex + 9)];
        return version;
    }

    private string ConvertMarkdownToHtml(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
            return "<p>No release notes available.</p>";

        var pipeline = new Markdig.MarkdownPipelineBuilder()
            .UseAdvancedExtensions()
            .DisableHtml()
            .Build();

        return Markdig.Markdown.ToHtml(markdown, pipeline);
    }
}

<style>
    .dialog-content {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .dialog-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
    }

    .dialog-header h2 {
        margin: 0;
        font-size: 1.25rem;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 600;
    }

    .dialog-header h2 i {
        color: var(--accent-purple);
    }

    .dialog-body {
        padding: 1.5rem;
        overflow-y: auto;
        flex: 1;
    }

    .version-info {
        display: flex;
        align-items: stretch;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .version-badge {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.375rem;
        padding: 1rem 1.5rem;
        border-radius: 0.625rem;
        flex: 1;
    }

    .version-badge.current {
        background: var(--bg-tertiary);
        border: 1px solid var(--border-color, rgba(128,128,128,0.15));
    }

    .version-badge.new {
        background: rgba(52, 211, 153, 0.08);
        border: 2px solid rgba(52, 211, 153, 0.4);
    }

    .version-badge .label {
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        font-weight: 600;
    }

    .version-badge.current .version {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--text-secondary);
    }

    .version-badge.new .version {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--accent-success, #34d399);
    }

    .version-info > .version-arrow {
        color: var(--text-muted);
        font-size: 1.25rem;
        flex-shrink: 0;
        display: flex;
        align-items: center;
    }

    .release-date {
        font-size: 0.75rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.375rem;
    }

    .release-notes {
        margin-top: 0.75rem;
    }

    .release-notes-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.75rem;
    }

    .release-notes-header h4 {
        margin: 0;
        font-size: 1rem;
        color: var(--text-primary);
        font-weight: 600;
    }

    .notes-content {
        padding: 1rem;
        background: var(--bg-tertiary);
        border-radius: 0.5rem;
        max-height: 250px;
        overflow-y: auto;
        font-size: 0.875rem;
        line-height: 1.6;
        color: var(--text-secondary);
    }

    .dialog-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        padding: 1.25rem 1.5rem;
        border-top: 1px solid var(--border-color);
    }

    .update-progress {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        width: 100%;
    }

    .progress-bar-container {
        width: 100%;
        height: 6px;
        background: var(--bg-tertiary);
        border-radius: 3px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--accent-purple), var(--accent-success));
        border-radius: 3px;
        transition: width 0.3s ease;
    }

    .progress-text {
        font-size: 0.8125rem;
        color: var(--text-muted);
        text-align: center;
    }

    .update-error {
        flex: 1;
    }

    .error-text {
        font-size: 0.8125rem;
        color: var(--accent-danger, #ef4444);
    }

    .error-text i {
        margin-right: 0.375rem;
    }
</style>
