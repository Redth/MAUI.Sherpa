@page "/modal/runtime-picker"
@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Pages.Forms
@inject HybridFormBridgeHolder BridgeHolder
@implements IDisposable

@{
    var bridge = BridgeHolder.Current;
}

@if (bridge != null)
{
    <div class="runtime-picker-dialog">
        <div class="runtime-picker-toolbar">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text"
                       @bind="searchQuery"
                       @bind:event="oninput"
                       placeholder="Search versions, builds, or platforms..." />
                @if (!string.IsNullOrEmpty(searchQuery))
                {
                    <button class="clear-search" @onclick="@(() => searchQuery = string.Empty)">×</button>
                }
            </div>

            <div class="platform-filter">
                <select id="runtime-platform-filter" @bind="selectedPlatform">
                    <option value="All">All Platforms</option>
                    <option value="iOS">iOS</option>
                    <option value="watchOS">watchOS</option>
                    <option value="tvOS">tvOS</option>
                    <option value="visionOS">visionOS</option>
                </select>
            </div>
        </div>

        <div class="runtime-picker-options">
            <label class="toggle-label">
                <input type="checkbox" @bind="showPrerelease" @bind:event="oninput" />
                <span>Show Betas &amp; RCs</span>
            </label>
            <span class="results-count">Showing @FilteredRuntimes.Count runtime(s)</span>
        </div>

        <div class="runtime-picker-hint">
            Select a runtime to enable the native <strong>Install</strong> button.
        </div>

        <div class="selection-list">
            @foreach (var runtime in FilteredRuntimes)
            {
                var isInstalled = installedRuntimeBuilds.Contains(runtime.Build);
                <label class="runtime-item @(selectedRuntime?.Build == runtime.Build ? "selected" : "") @(isInstalled ? "disabled" : "")"
                       @onclick="@(() => SelectRuntime(runtime, isInstalled))">
                    <div class="runtime-icon">
                        <i class="@GetRuntimeIcon(runtime.PlatformIdentifier)"></i>
                    </div>
                    <div class="runtime-content">
                        <div class="runtime-title">
                            @FormatRuntimeName(runtime)
                            @if (runtime.IsPrerelease)
                            {
                                <span class="badge badge-beta">Prerelease</span>
                            }
                            @if (isInstalled)
                            {
                                <span class="badge badge-installed"><i class="fas fa-check"></i> Installed</span>
                            }
                        </div>
                        <div class="runtime-details">
                            <span class="detail-item"><i class="fas fa-desktop"></i> @FriendlyPlatform(runtime.PlatformIdentifier)</span>
                            <span class="detail-item"><i class="fas fa-code-branch"></i> Build @runtime.Build</span>
                            @if (runtime.FileSizeBytes > 0)
                            {
                                <span class="detail-item"><i class="fas fa-weight"></i> @FormatBytes(runtime.FileSizeBytes)</span>
                            }
                            @if (runtime.Architectures.Count > 0)
                            {
                                <span class="detail-item"><i class="fas fa-microchip"></i> @string.Join(" / ", runtime.Architectures)</span>
                            }
                        </div>
                    </div>
                    @if (selectedRuntime?.Build == runtime.Build)
                    {
                        <i class="fas fa-check selected-mark"></i>
                    }
                </label>
            }

            @if (FilteredRuntimes.Count == 0)
            {
                <div class="empty-hint">No matching runtimes</div>
            }
        </div>
    </div>
}

<style>
    .runtime-picker-dialog {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
    }

    .runtime-picker-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 180px;
        gap: 0.75rem;
        align-items: end;
    }

    .search-box {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--input-bg, #edf2f7);
        border-radius: 6px;
        min-height: 40px;
        padding: 0 0.75rem;
        border: 1px solid var(--border-color, #e2e8f0);
        box-sizing: border-box;
    }

    .search-box i {
        color: var(--text-muted, #a0aec0);
        font-size: 0.8rem;
        flex-shrink: 0;
    }

    .search-box input {
        flex: 1;
        height: 100%;
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.875rem;
        color: var(--text-primary, #1a202c);
    }

    .clear-search {
        background: none;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 1rem;
        padding: 0 4px;
        line-height: 1;
    }

    .platform-filter select {
        width: 100%;
        height: 40px;
        padding: 0 0.75rem;
        border: 1px solid var(--border-color);
        border-radius: 0.375rem;
        background: var(--bg-secondary);
        color: var(--text-primary);
        font-size: 0.875rem;
        box-sizing: border-box;
    }

    .runtime-picker-options {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .toggle-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: var(--text-secondary);
        cursor: pointer;
    }

    .toggle-label input[type="checkbox"] {
        accent-color: var(--accent-primary);
    }

    .results-count,
    .runtime-picker-hint {
        font-size: 0.8125rem;
        color: var(--text-muted);
    }

    .selection-list {
        display: flex;
        flex-direction: column;
        gap: 0;
        max-height: 420px;
        overflow: hidden auto;
        border: 1px solid var(--border-color);
        border-radius: 0.875rem;
        background: var(--card-bg);
    }

    .runtime-item {
        display: flex;
        align-items: flex-start;
        gap: 0.875rem;
        padding: 0.875rem 1rem;
        border: none;
        border-radius: 0;
        background: transparent;
        cursor: pointer;
        transition: background 0.15s, box-shadow 0.15s;
    }

    .runtime-item + .runtime-item {
        border-top: 1px solid var(--border-color);
    }

    .runtime-item:first-child {
        border-top-left-radius: calc(0.875rem - 1px);
        border-top-right-radius: calc(0.875rem - 1px);
    }

    .runtime-item:last-child {
        border-bottom-left-radius: calc(0.875rem - 1px);
        border-bottom-right-radius: calc(0.875rem - 1px);
    }

    .runtime-item:hover:not(.disabled) {
        background: var(--hover-bg, rgba(0, 0, 0, 0.04));
    }

    .runtime-item.selected {
        background: var(--accent-bg, rgba(139, 92, 246, 0.08));
        box-shadow: inset 0 0 0 1px var(--accent-primary);
    }

    .runtime-item.disabled {
        opacity: 0.7;
        cursor: default;
    }

    .runtime-icon {
        width: 2rem;
        height: 2rem;
        border-radius: 0.625rem;
        background: var(--bg-tertiary);
        color: var(--accent-primary);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .runtime-content {
        flex: 1;
        min-width: 0;
    }

    .runtime-title {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.25rem;
    }

    .runtime-details {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 0.875rem;
        font-size: 0.8125rem;
        color: var(--text-secondary);
    }

    .detail-item {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
    }

    .selected-mark {
        color: var(--accent-primary);
        margin-top: 0.2rem;
    }

    .empty-hint {
        text-align: center;
        color: var(--text-muted);
        padding: 2rem;
        font-size: 0.85rem;
    }
</style>

@code {
    private string searchQuery = string.Empty;
    private string selectedPlatform = "All";
    private bool showPrerelease;
    private IReadOnlyList<DownloadableSimulatorRuntime> runtimes = Array.Empty<DownloadableSimulatorRuntime>();
    private HashSet<string> installedRuntimeBuilds = new(StringComparer.OrdinalIgnoreCase);
    private DownloadableSimulatorRuntime? selectedRuntime;

    private List<DownloadableSimulatorRuntime> FilteredRuntimes =>
        runtimes
            .Where(runtime => showPrerelease || !runtime.IsPrerelease)
            .Where(MatchesPlatformFilter)
            .Where(MatchesSearch)
            .OrderBy(runtime => GetPlatformSortOrder(runtime.PlatformIdentifier))
            .ThenByDescending(runtime => ParseComparableVersion(runtime.Version))
            .ThenByDescending(runtime => runtime.Build, StringComparer.OrdinalIgnoreCase)
            .ThenBy(runtime => runtime.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

    protected override void OnInitialized()
    {
        var bridge = BridgeHolder.Current;
        if (bridge == null)
            return;

        if (bridge.Parameters.TryGetValue("DownloadableRuntimes", out var runtimeValue) &&
            runtimeValue is IReadOnlyList<DownloadableSimulatorRuntime> runtimeList)
        {
            runtimes = runtimeList;
        }

        if (bridge.Parameters.TryGetValue("InstalledRuntimeBuilds", out var installedBuildValue) &&
            installedBuildValue is IReadOnlyList<string> installedBuildList)
        {
            installedRuntimeBuilds = new HashSet<string>(installedBuildList, StringComparer.OrdinalIgnoreCase);
        }

        bridge.SubmitRequested += OnSubmit;
        bridge.CancelRequested += OnCancel;
        bridge.SetValid(false);
    }

    private bool MatchesPlatformFilter(DownloadableSimulatorRuntime runtime) =>
        string.Equals(selectedPlatform, "All", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(FriendlyPlatform(runtime.PlatformIdentifier), selectedPlatform, StringComparison.OrdinalIgnoreCase);

    private bool MatchesSearch(DownloadableSimulatorRuntime runtime)
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
            return true;

        var query = searchQuery.Trim();
        return runtime.Name.Contains(query, StringComparison.OrdinalIgnoreCase) ||
               FriendlyPlatform(runtime.PlatformIdentifier).Contains(query, StringComparison.OrdinalIgnoreCase) ||
               runtime.Version.Contains(query, StringComparison.OrdinalIgnoreCase) ||
               runtime.Build.Contains(query, StringComparison.OrdinalIgnoreCase);
    }

    private void SelectRuntime(DownloadableSimulatorRuntime runtime, bool isInstalled)
    {
        if (isInstalled)
            return;

        selectedRuntime = runtime;
        var bridge = BridgeHolder.Current;
        if (bridge == null)
            return;

        bridge.Result = selectedRuntime;
        bridge.SetValid(true);
        StateHasChanged();
    }

    private Task OnSubmit()
    {
        var bridge = BridgeHolder.Current;
        if (bridge != null)
            bridge.Result = selectedRuntime;

        return Task.CompletedTask;
    }

    private void OnCancel()
    {
        var bridge = BridgeHolder.Current;
        if (bridge != null)
            bridge.Result = null;

        selectedRuntime = null;
    }

    public void Dispose()
    {
        var bridge = BridgeHolder.Current;
        if (bridge != null)
        {
            bridge.SubmitRequested -= OnSubmit;
            bridge.CancelRequested -= OnCancel;
        }
    }

    private static string FormatRuntimeName(DownloadableSimulatorRuntime runtime)
    {
        const string suffix = " Simulator Runtime";
        return runtime.Name.EndsWith(suffix, StringComparison.OrdinalIgnoreCase)
            ? runtime.Name[..^suffix.Length]
            : runtime.Name;
    }

    private static string FriendlyPlatform(string? platformIdentifier) => platformIdentifier switch
    {
        "com.apple.platform.iphonesimulator" or "com.apple.platform.iphoneos" => "iOS",
        "com.apple.platform.watchos" or "com.apple.platform.watchsimulator" => "watchOS",
        "com.apple.platform.tvos" or "com.apple.platform.appletvos" or "com.apple.platform.tvsimulator" or "com.apple.platform.appletvsimulator" => "tvOS",
        "com.apple.platform.xros" or "com.apple.platform.xrsimulator" => "visionOS",
        "com.apple.platform.macosx" => "macOS",
        null or "" => "Unknown Platform",
        _ => platformIdentifier
    };

    private static string GetRuntimeIcon(string? platformIdentifier) => FriendlyPlatform(platformIdentifier) switch
    {
        "iOS" => "fas fa-mobile-alt",
        "watchOS" => "fas fa-clock",
        "tvOS" => "fas fa-tv",
        "visionOS" => "fas fa-vr-cardboard",
        "macOS" => "fas fa-laptop",
        _ => "fas fa-cube"
    };

    private static int GetPlatformSortOrder(string? platformIdentifier) => FriendlyPlatform(platformIdentifier) switch
    {
        "iOS" => 0,
        "watchOS" => 1,
        "tvOS" => 2,
        "visionOS" => 3,
        "macOS" => 4,
        _ => 5
    };

    private static Version ParseComparableVersion(string version)
    {
        if (Version.TryParse(version, out var parsed))
            return parsed;

        var segments = version
            .Split('.', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(segment => int.TryParse(segment, out var value) ? value : 0)
            .Take(4)
            .ToList();

        while (segments.Count < 4)
            segments.Add(0);

        return new Version(segments[0], segments[1], segments[2], segments[3]);
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }
}
