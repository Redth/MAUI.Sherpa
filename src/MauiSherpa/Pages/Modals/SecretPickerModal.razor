@page "/modal/secret-picker"
@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Pages.Forms
@inject HybridFormBridgeHolder BridgeHolder
@implements IDisposable

@{
    var bridge = BridgeHolder.Current;
}

@if (bridge != null)
{
    <div class="form-content">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="Search managed secrets..." />
            @if (!string.IsNullOrEmpty(searchQuery))
            {
                <button class="clear-search" @onclick="@(() => searchQuery = "")">×</button>
            }
        </div>

        <div class="selection-list">
            @foreach (var secret in FilteredSecrets)
            {
                var isExisting = existingKeys.Contains(secret.Key);
                <label class="selection-item @(selectedKey == secret.Key ? "selected" : "") @(isExisting ? "disabled" : "")"
                       @onclick="@(() => { if (!isExisting) SelectSecret(secret.Key); })">
                    <div class="item-content">
                        <div class="item-name mono">@secret.Key</div>
                        <div class="item-detail">
                            @if (isExisting)
                            {
                                <span class="already-added">Already added</span>
                            }
                            else
                            {
                                @(string.IsNullOrEmpty(secret.Description) ? "\u00A0" : secret.Description)
                            }
                        </div>
                    </div>
                    @if (selectedKey == secret.Key)
                    {
                        <i class="fas fa-check" style="color: var(--accent-color, #8b5cf6);"></i>
                    }
                </label>
            }
            @if (!FilteredSecrets.Any())
            {
                <div class="empty-hint">No matching secrets</div>
            }
        </div>
    </div>
}

<style>
    .form-content { display: flex; flex-direction: column; gap: 0.75rem; }
    .search-box {
        display: flex; align-items: center; gap: 0.5rem;
        background: var(--input-bg, #edf2f7); border-radius: 6px; padding: 0.5rem 0.75rem;
        border: 1px solid var(--border-color, #e2e8f0);
    }
    .search-box i { color: var(--text-muted, #a0aec0); font-size: 0.8rem; flex-shrink: 0; }
    .search-box input {
        flex: 1; border: none; background: transparent; outline: none; font-size: 0.85rem;
        color: var(--text-primary, #1a202c);
    }
    .clear-search {
        background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 1rem;
        padding: 0 4px; line-height: 1;
    }
    .selection-list {
        display: flex; flex-direction: column; gap: 2px;
        max-height: 320px; overflow-y: auto;
    }
    .selection-item {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.5rem 0.75rem; border-radius: 6px; cursor: pointer;
        transition: background 0.15s;
    }
    .selection-item:hover:not(.disabled) { background: var(--hover-bg, rgba(0,0,0,0.04)); }
    .selection-item.selected { background: var(--accent-bg, rgba(139,92,246,0.08)); }
    .selection-item.disabled { opacity: 0.5; cursor: not-allowed; }
    .item-content { flex: 1; min-width: 0; }
    .item-name { font-size: 0.85rem; font-weight: 500; color: var(--text-primary); }
    .item-name.mono { font-family: "SF Mono", Menlo, Monaco, monospace; font-size: 0.8rem; }
    .item-detail { font-size: 0.75rem; color: var(--text-secondary, #718096); margin-top: 2px; }
    .already-added { color: var(--text-muted, #a0aec0); font-style: italic; }
    .empty-hint {
        text-align: center; color: var(--text-muted); padding: 2rem; font-size: 0.85rem;
    }
</style>

@code {
    private string searchQuery = "";
    private string? selectedKey;
    private IReadOnlyList<ManagedSecret> managedSecrets = Array.Empty<ManagedSecret>();
    private HashSet<string> existingKeys = new();

    private IEnumerable<ManagedSecret> FilteredSecrets =>
        string.IsNullOrEmpty(searchQuery)
            ? managedSecrets
            : managedSecrets.Where(s =>
                s.Key.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                (s.Description?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override void OnInitialized()
    {
        var bridge = BridgeHolder.Current;
        if (bridge == null) return;

        if (bridge.Parameters.TryGetValue("ManagedSecrets", out var ms) && ms is IReadOnlyList<ManagedSecret> secrets)
            managedSecrets = secrets;

        if (bridge.Parameters.TryGetValue("ExistingKeys", out var ek) && ek is IReadOnlyList<string> keys)
            existingKeys = new HashSet<string>(keys);

        bridge.SubmitRequested += OnSubmit;
        bridge.CancelRequested += OnCancel;

        // Initially invalid until a secret is selected
        bridge.SetValid(false);
    }

    private void SelectSecret(string key)
    {
        selectedKey = key;
        var bridge = BridgeHolder.Current;
        if (bridge == null) return;
        bridge.Result = selectedKey;
        bridge.SetValid(true);
        StateHasChanged();
    }

    private Task OnSubmit()
    {
        var bridge = BridgeHolder.Current;
        if (bridge != null)
            bridge.Result = selectedKey;
        return Task.CompletedTask;
    }

    private void OnCancel()
    {
        var bridge = BridgeHolder.Current;
        if (bridge != null)
            bridge.Result = null;
    }

    public void Dispose()
    {
        var bridge = BridgeHolder.Current;
        if (bridge != null)
        {
            bridge.SubmitRequested -= OnSubmit;
            bridge.CancelRequested -= OnCancel;
        }
    }
}
