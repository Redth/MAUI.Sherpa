@page "/mobile-doctor"
@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Core.Services
@inject IMobileDoctorService MobileDoctorService
@inject IToolbarService ToolbarService
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="page-header">
    <div class="page-title-row">
        <h1><i class="fas fa-stethoscope"></i> Mobile Doctor</h1>
    </div>
    <p class="page-subtitle">
        Check the core Android, Java, and Apple tooling needed for a healthy mobile development setup.
    </p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-error">
        <i class="fas fa-triangle-exclamation"></i>
        <span>@errorMessage</span>
    </div>
}
else if (isLoading)
{
    <div class="loading-state">
        <i class="fas fa-spinner fa-spin"></i>
        <span>@(string.IsNullOrWhiteSpace(progressMessage) ? "Running doctor..." : progressMessage)</span>
    </div>
}
else if (report is not null)
{
    <div class="summary-grid">
        <div class="summary-card summary-ok">
            <div class="summary-count">@report.OkCount</div>
            <div class="summary-label">Ready</div>
        </div>
        <div class="summary-card summary-warning">
            <div class="summary-count">@report.WarningCount</div>
            <div class="summary-label">Warnings</div>
        </div>
        <div class="summary-card summary-error">
            <div class="summary-count">@report.ErrorCount</div>
            <div class="summary-label">Errors</div>
        </div>
    </div>

    <div class="section-list">
        @foreach (var doctorSection in report.Sections)
        {
            <section class="doctor-section">
                <header class="doctor-section-header">
                    <h2>@doctorSection.Title</h2>
                    <span class="section-count">@doctorSection.Checks.Count check(s)</span>
                </header>

                <div class="check-list">
                    @foreach (var check in doctorSection.Checks)
                    {
                        <article class="check-card @GetStatusClass(check.Status)">
                            <div class="check-header">
                                <div class="check-title-row">
                                    <span class="check-icon"><i class="@GetStatusIcon(check.Status)"></i></span>
                                    <h3>@check.Name</h3>
                                </div>
                                <span class="check-status">@GetStatusText(check.Status)</span>
                            </div>
                            <p class="check-summary">@check.Summary</p>
                            @if (check.Details?.Count > 0)
                            {
                                <ul class="check-details">
                                    @foreach (var detail in check.Details)
                                    {
                                        <li>@detail</li>
                                    }
                                </ul>
                            }
                        </article>
                    }
                </div>
            </section>
        }
    </div>
}

@code {
    private MobileDoctorReport? report;
    private bool isLoading;
    private string errorMessage = string.Empty;
    private string progressMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!ProductInfo.Capabilities.HasMobileDoctor)
        {
            NavigationManager.NavigateTo(ProductInfo.DoctorRoute);
            return;
        }

        ToolbarService.SetItems(
            new ToolbarAction("refresh", "Run Doctor", "arrow.clockwise")
        );
        ToolbarService.ToolbarItemClicked += OnToolbarItemClicked;

        await RunDoctorAsync();
    }

    public void Dispose()
    {
        ToolbarService.ToolbarItemClicked -= OnToolbarItemClicked;
    }

    private void OnToolbarItemClicked(string actionId)
    {
        if (actionId == "refresh")
        {
            _ = InvokeAsync(RunDoctorAsync);
        }
    }

    private async Task RunDoctorAsync()
    {
        isLoading = true;
        errorMessage = string.Empty;
        progressMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            var progress = new Progress<string>(message =>
            {
                progressMessage = message;
                InvokeAsync(StateHasChanged);
            });

            report = await MobileDoctorService.RunDoctorAsync(progress);
        }
        catch (Exception ex)
        {
            errorMessage = $"Mobile doctor failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            progressMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetStatusClass(MobileDoctorCheckStatus status) => status switch
    {
        MobileDoctorCheckStatus.Ok => "status-ok",
        MobileDoctorCheckStatus.Warning => "status-warning",
        _ => "status-error"
    };

    private static string GetStatusIcon(MobileDoctorCheckStatus status) => status switch
    {
        MobileDoctorCheckStatus.Ok => "fas fa-circle-check",
        MobileDoctorCheckStatus.Warning => "fas fa-triangle-exclamation",
        _ => "fas fa-circle-xmark"
    };

    private static string GetStatusText(MobileDoctorCheckStatus status) => status switch
    {
        MobileDoctorCheckStatus.Ok => "Ready",
        MobileDoctorCheckStatus.Warning => "Warning",
        _ => "Error"
    };
}

<style>
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin: 1.5rem 0;
    }

    .summary-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 1.25rem;
    }

    .summary-ok {
        box-shadow: inset 0 0 0 1px rgba(34, 197, 94, 0.18);
    }

    .summary-warning {
        box-shadow: inset 0 0 0 1px rgba(245, 158, 11, 0.18);
    }

    .summary-error {
        box-shadow: inset 0 0 0 1px rgba(239, 68, 68, 0.18);
    }

    .summary-count {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
    }

    .summary-label {
        margin-top: 0.25rem;
        color: var(--text-secondary);
        font-size: 0.95rem;
    }

    .section-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .doctor-section {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 18px;
        padding: 1.25rem;
    }

    .doctor-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .doctor-section-header h2 {
        margin: 0;
        font-size: 1.1rem;
    }

    .section-count {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .check-list {
        display: grid;
        gap: 0.9rem;
    }

    .check-card {
        border-radius: 14px;
        padding: 1rem 1.1rem;
        background: var(--bg-tertiary);
        border: 1px solid transparent;
    }

    .check-card.status-ok {
        border-color: rgba(34, 197, 94, 0.2);
    }

    .check-card.status-warning {
        border-color: rgba(245, 158, 11, 0.24);
    }

    .check-card.status-error {
        border-color: rgba(239, 68, 68, 0.24);
    }

    .check-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.5rem;
    }

    .check-title-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 0;
    }

    .check-title-row h3 {
        margin: 0;
        font-size: 1rem;
    }

    .check-icon {
        color: var(--text-secondary);
    }

    .check-status {
        color: var(--text-secondary);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .check-summary {
        margin: 0;
        color: var(--text-primary);
    }

    .check-details {
        margin: 0.75rem 0 0;
        padding-left: 1.1rem;
        color: var(--text-secondary);
    }

    .check-details li + li {
        margin-top: 0.35rem;
    }
</style>
