    private RenderFragment RenderPropertyEditor(PropertyEntry prop) => __builder =>
    {
        switch (prop.Meta.Editor)
        {
            case EditorType.Boolean:
                RenderBoolEditor(prop)(__builder);
                break;
            case EditorType.Enum:
                RenderEnumEditor(prop)(__builder);
                break;
            case EditorType.Color:
                RenderColorEditor(prop)(__builder);
                break;
            case EditorType.Thickness:
                RenderThicknessEditor(prop)(__builder);
                break;
            case EditorType.Number:
                RenderNumberEditor(prop)(__builder);
                break;
            default:
                RenderTextEditor(prop)(__builder);
                break;
        }
    };

