    private RenderFragment RenderPropertyEditor(PropertyEntry prop) => __builder =>
    {
        var fragment = prop.Meta.Editor switch
        {
            EditorType.Boolean => RenderBoolEditor(prop),
            EditorType.Enum => RenderEnumEditor(prop),
            EditorType.Color => RenderColorEditor(prop),
            EditorType.Brush => RenderBrushEditor(prop),
            EditorType.Thickness => RenderThicknessEditor(prop),
            EditorType.Number => RenderNumberEditor(prop),
            _ => RenderTextEditor(prop),
        };
        __builder.AddContent(0, fragment);
    };

