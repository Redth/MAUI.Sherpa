    private void StartEditing(string property, string? currentValue)
    {
        editingProperty = property;
        editValue = currentValue ?? "";
        StateHasChanged();
    }

    private async Task OnEditKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && selectedElement != null && editingProperty != null)
        {
            await CommitEdit();
        }
        else if (e.Key == "Escape")
        {
            editingProperty = null;
            StateHasChanged();
        }
    }

    private async Task OnEditBlur()
    {
        if (selectedElement != null && editingProperty != null)
        {
            await CommitEdit();
        }
    }

    private async Task CommitEdit()
    {
        if (selectedElement == null || editingProperty == null) return;
        var prop = editingProperty;
        var val = editValue;
        var elementId = selectedElement.Id;
        editingProperty = null;
        gradientStops.Clear();
        selectedStopIndex = null;
        isDraggingStop = false;
        StateHasChanged();
        await Client.SetPropertyAsync(elementId, prop, val);
        await RefreshTree();
        await RefreshProperties();
    }

    private async Task OnTrackPointerMove(PointerEventArgs e)
    {
        if (!isDraggingStop || !selectedStopIndex.HasValue || selectedStopIndex.Value >= gradientStops.Count)
            return;

        try
        {
            var rect = await JS.InvokeAsync<TrackRect>("eval",
                $"(function(){{ var el=document.querySelector('.gradient-track-container'); if(!el) return null; var r=el.getBoundingClientRect(); return {{ left: r.left, width: r.width }}; }})()");
            if (rect != null && rect.Width > 0)
            {
                var offset = (e.ClientX - rect.Left) / rect.Width;
                offset = Math.Clamp(offset, 0, 1);
                gradientStops[selectedStopIndex.Value].Offset = offset;
                var currentType = DetectEditBrushType();
                editValue = BuildGradientCss(currentType);
                StateHasChanged();
            }
        }
        catch { }
    }

    private record TrackRect(double Left, double Width);

    private async Task RefreshProperties()
    {
        if (selectedElement == null) return;
        var elementId = selectedElement.Id;

        isLoadingProps = true;
        StateHasChanged();

        try
        {
            var tasks = CommonProperties.Select(async prop =>
            {
                var val = await Client.GetPropertyAsync(elementId, prop);
                return new PropertyEntry(prop, val, GetMeta(prop));
            });

            var results = await Task.WhenAll(tasks);

            if (selectedElementId == elementId)
            {
                fetchedProperties = results
                    .Where(p => p.Value != null)
                    .OrderBy(p => Array.IndexOf(GroupOrder, p.Meta.Group))
                    .ThenBy(p => p.Name)
                    .ToList();
            }
        }
        catch { }
        finally
        {
            isLoadingProps = false;
            StateHasChanged();
        }
    }

    private static string GetPropertyValueClass(string? value)
    {
        if (value == null) return "";
        if (value.Equals("True", StringComparison.OrdinalIgnoreCase)) return "val-true";
        if (value.Equals("False", StringComparison.OrdinalIgnoreCase)) return "val-false";
        return "";
    }

