    // --- Toggle, Focus, Custom query ---

    private async Task ToggleBoolProperty(string propertyName, bool currentValue)
    {
        if (selectedElement == null) return;
        await Client.SetPropertyAsync(selectedElement.Id, propertyName, (!currentValue).ToString());
        await RefreshTree();
        await RefreshProperties();
    }

    private async Task FocusSelected()
    {
        if (selectedElement == null) return;
        await Client.FocusAsync(selectedElement.Id);
        await RefreshTree();
    }

    private async Task FetchCustomProperty()
    {
        if (selectedElement == null || string.IsNullOrWhiteSpace(customPropertyName)) return;
        var name = customPropertyName.Trim();
        var val = await Client.GetPropertyAsync(selectedElement.Id, name);
        if (val != null)
        {
            var meta = GetMeta(name);
            // Remove existing entry with same name if any
            fetchedProperties.RemoveAll(p => p.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
            fetchedProperties.Insert(0, new PropertyEntry(name, val, meta));
        }
        customPropertyName = "";
        StateHasChanged();
    }

    private async Task OnCustomPropertyKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await FetchCustomProperty();
    }

    private async Task CommitThickness(string propName, string top, string right, string bottom, string left)
    {
        if (selectedElement == null) return;
        await Client.SetPropertyAsync(selectedElement.Id, propName, $"{left},{top},{right},{bottom}");
        await RefreshTree();
        await RefreshProperties();
    }

    // --- Color parsing helpers ---

    private static string MauiColorToCss(string? value)
    {
        if (string.IsNullOrEmpty(value)) return "transparent";
        if (value.StartsWith("#")) return value;
        // Parse "Color [A=1, R=0.5, G=0.5, B=0.5, ...]" format
        if (value.StartsWith("Color [") || value.StartsWith("[Color:"))
        {
            var parts = value.Split(new[] { 'A', 'R', 'G', 'B', '=', ',', '[', ']', ' ' }, StringSplitOptions.RemoveEmptyEntries);
            var nums = parts.Where(p => double.TryParse(p, out _)).Select(p => double.Parse(p)).ToArray();
            if (nums.Length >= 4)
            {
                var a = nums[0]; var r = (int)(nums[1] * 255); var g = (int)(nums[2] * 255); var b = (int)(nums[3] * 255);
                return $"rgba({r},{g},{b},{a:F2})";
            }
        }
        // Named colors
        return value.ToLowerInvariant() switch
        {
            "transparent" => "transparent",
            _ => value.ToLowerInvariant()
        };
    }

    private static string MauiColorToHex(string? value)
    {
        if (string.IsNullOrEmpty(value)) return "#000000";
        if (value.StartsWith("#") && value.Length >= 7) return value[..7];
        if (value.StartsWith("Color [") || value.StartsWith("[Color:"))
        {
            var parts = value.Split(new[] { 'A', 'R', 'G', 'B', '=', ',', '[', ']', ' ' }, StringSplitOptions.RemoveEmptyEntries);
            var nums = parts.Where(p => double.TryParse(p, out _)).Select(p => double.Parse(p)).ToArray();
            if (nums.Length >= 4)
            {
                var r = (int)(nums[1] * 255); var g = (int)(nums[2] * 255); var b = (int)(nums[3] * 255);
                return $"#{r:X2}{g:X2}{b:X2}";
            }
        }
        return "#000000";
    }

    // --- Thickness parsing ---

    private static (string top, string right, string bottom, string left) ParseThickness(string? value)
    {
        if (string.IsNullOrEmpty(value)) return ("0", "0", "0", "0");
        // Format: "{Left=0 Top=0 Right=0 Bottom=0}" or "L, T, R, B" or uniform "X"
        var nums = System.Text.RegularExpressions.Regex.Matches(value, @"-?[\d.]+")
            .Select(m => m.Value).ToArray();
        return nums.Length switch
        {
            >= 4 => (nums[1], nums[2], nums[3], nums[0]), // MAUI order: Left, Top, Right, Bottom
            3 => (nums[1], nums[2], nums[1], nums[0]),
            2 => (nums[1], nums[0], nums[1], nums[0]),
            1 => (nums[0], nums[0], nums[0], nums[0]),
            _ => ("0", "0", "0", "0")
        };
    }

    private void OnAutoRefreshChanged()
    {
        _screenshotTimer?.Dispose();
        _screenshotTimer = null;

        if (autoRefreshInterval > 0)
        {
            var interval = TimeSpan.FromSeconds(autoRefreshInterval);
            _screenshotTimer = new Timer(async _ =>
            {
                await InvokeAsync(async () =>
                {
                    await RefreshScreenshot();
                });
            }, null, interval, interval);
        }
    }

    private static string Truncate(string text, int max)
        => text.Length <= max ? text : text[..max] + "…";

    public void Dispose()
    {
        _screenshotTimer?.Dispose();
    }
}

