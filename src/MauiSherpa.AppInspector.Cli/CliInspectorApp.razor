<Router AppAssembly="@typeof(CliInspectorApp).Assembly" AdditionalAssemblies="@InspectorAssemblies">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MauiSherpa.AppInspector.Components.InspectorLayout)" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(MauiSherpa.AppInspector.Components.InspectorLayout)">
            <div style="padding: 1rem;">Inspector route not found.</div>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private static readonly System.Reflection.Assembly[] InspectorAssemblies =
    [
        typeof(MauiSherpa.AppInspector.InspectorApp).Assembly
    ];
}
